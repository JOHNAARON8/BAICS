                                                    <label class="block text-xs font-medium text-slate-500 mb-1">Date Format</label>
                                                    <select class="w-full px-3 py-2 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm">
                                                        <option>MM/DD/YYYY</option>
                                                        <option>DD/MM/YYYY</option>
                                                        <option>YYYY-MM-DD</option>
                                                    </select>
                                                </div>
                                                <div>
                                                    <label class="block text-xs font-medium text-slate-500 mb-1">Time Format</label>
                                                    <select class="w-full px-3 py-2 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm">
                                                        <option>12-hour (AM/PM)</option>
                                                        <option>24-hour</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Dashboard Layout -->
                                        <div class="pt-4 border-t border-slate-100 dark:border-slate-800">
                                            <h4 class="font-bold text-sm mb-4">Default Dashboard View</h4>
                                            <div class="space-y-2">
                                                <label class="flex items-center gap-2">
                                                    <input type="radio" name="dashboard-view" checked class="text-primary">
                                                    <span class="text-sm">Compact View (show more cards)</span>
                                                </label>
                                                <label class="flex items-center gap-2">
                                                    <input type="radio" name="dashboard-view" class="text-primary">
                                                    <span class="text-sm">Detailed View (show full information)</span>
                                                </label>
                                            </div>
                                        </div>

                                        <!-- Save Button -->
                                        <div class="flex justify-end gap-3 pt-4 border-t border-slate-100 dark:border-slate-800">
                                            <button type="button" class="px-4 py-2 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-primary transition-colors">
                                                Reset to Default
                                            </button>
                                            <button type="button" class="px-6 py-2 bg-primary hover:bg-primary/90 text-white rounded-lg text-sm font-bold transition-colors shadow-lg shadow-primary/20">
                                                Save Preferences
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Privacy Tab -->
                            <div id="settings-privacy" class="settings-content hidden">
                                <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden">
                                    <div class="p-4 lg:p-6 border-b border-slate-100 dark:border-slate-800">
                                        <h3 class="text-lg font-bold">Privacy Settings</h3>
                                        <p class="text-xs lg:text-sm text-slate-500">Control your privacy and data sharing preferences</p>
                                    </div>
                                    
                                    <div class="p-4 lg:p-6 space-y-6">
                                        <!-- Profile Visibility -->
                                        <div>
                                            <h4 class="font-bold text-sm mb-4">Profile Visibility</h4>
                                            <div class="space-y-3">
                                                <div class="flex items-center justify-between">
                                                    <div>
                                                        <p class="text-sm font-medium">Show my profile to other department heads</p>
                                                        <p class="text-xs text-slate-500">Your name and department will be visible</p>
                                                    </div>
                                                    <label class="toggle-switch">
                                                        <input type="checkbox" checked>
                                                        <span class="toggle-slider"></span>
                                                    </label>
                                                </div>
                                                <div class="flex items-center justify-between">
                                                    <div>
                                                        <p class="text-sm font-medium">Show my survey activity</p>
                                                        <p class="text-xs text-slate-500">Let others see your completed surveys</p>
                                                    </div>
                                                    <label class="toggle-switch">
                                                        <input type="checkbox">
                                                        <span class="toggle-slider"></span>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Data Sharing -->
                                        <div class="pt-4 border-t border-slate-100 dark:border-slate-800">
                                            <h4 class="font-bold text-sm mb-4">Data Sharing</h4>
                                            <div class="space-y-3">
                                                <div class="flex items-center justify-between">
                                                    <div>
                                                        <p class="text-sm font-medium">Anonymous usage data</p>
                                                        <p class="text-xs text-slate-500">Help improve BAICS by sharing anonymous usage data</p>
                                                    </div>
                                                    <label class="toggle-switch">
                                                        <input type="checkbox" checked>
                                                        <span class="toggle-slider"></span>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Download Data -->
                                        <div class="pt-4 border-t border-slate-100 dark:border-slate-800">
                                            <h4 class="font-bold text-sm mb-4">Your Data</h4>
                                            <button class="px-4 py-2 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                                                Download My Data
                                            </button>
                                            <p class="text-xs text-slate-400 mt-2">Get a copy of all your survey responses and account data</p>
                                        </div>

                                        <!-- Delete Account -->
                                        <div class="pt-4 border-t border-slate-100 dark:border-slate-800">
                                            <h4 class="font-bold text-sm text-red-600 dark:text-red-400 mb-4">Danger Zone</h4>
                                            <div class="bg-red-50 dark:bg-red-900/10 border border-red-200 dark:border-red-800 rounded-lg p-4">
                                                <p class="text-sm font-medium text-red-800 dark:text-red-400 mb-2">Delete Account</p>
                                                <p class="text-xs text-red-600 dark:text-red-400 mb-3">Once you delete your account, there is no going back. Please be certain.</p>
                                                <button class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm font-bold transition-colors">
                                                    Delete Account
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Settings Tab Switching Script -->
    <script>
        function showSettingsTab(tabName) {
            // Hide all content
            document.querySelectorAll('.settings-content').forEach(content => {
                content.classList.add('hidden');
            });
            
            // Remove active class from all tabs
            document.querySelectorAll('.settings-tab').forEach(tab => {
                tab.classList.remove('active');
            });
            
            // Show selected content
            document.getElementById(`settings-${tabName}`).classList.remove('hidden');
            
            // Add active class to selected tab
            document.getElementById(`tab-${tabName}`).classList.add('active');
        }

        function cancelChanges() {
            if (confirm('Discard unsaved changes?')) {
                // Reset form or redirect
                window.location.reload();
            }
        }
    </script>

    <!-- Scripts -->
    <%- include('../partials/scripts') %>
</body>
</html>