<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Survey Submitted' }) %>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100">
    <!-- Mobile Menu Overlay -->
    <div id="mobileMenuOverlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden transition-opacity"></div>

    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <%- include('../partials/sidebar', { 
            role: 'office-head', 
            currentPage: 'my-surveys',
            user: user 
        }) %>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col min-w-0 h-screen overflow-hidden bg-background-light dark:bg-background-dark">
            <!-- Header -->
            <%- include('../partials/header', { 
                role: 'office-head', 
                pageTitle: 'Survey Submitted',
                user: user 
            }) %>

            <!-- Scrollable Content Area -->
            <div class="flex-1 overflow-y-auto custom-scrollbar">
                <div class="max-w-2xl mx-auto px-4 lg:px-6 py-6 lg:py-8">
                    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-8 lg:p-10 text-center">
                        <!-- Success Icon -->
                        <div class="w-20 h-20 bg-emerald-100 dark:bg-emerald-900/30 rounded-full flex items-center justify-center mx-auto mb-6">
                            <span class="material-symbols-outlined text-4xl text-emerald-600 dark:text-emerald-400">check_circle</span>
                        </div>

                        <h1 class="text-2xl lg:text-3xl font-black text-slate-900 dark:text-white mb-3">Survey Submitted Successfully!</h1>
                        <p class="text-sm lg:text-base text-slate-500 dark:text-slate-400 mb-6">
                            Thank you for completing the Internal Control Self-Assessment. Your responses have been recorded.
                        </p>

                        <!-- Submission Details -->
                        <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg p-4 mb-6 text-left">
                            <div class="grid grid-cols-2 gap-4 text-sm">
                                <div>
                                    <p class="text-xs text-slate-500">Submission ID</p>
                                    <p class="font-bold text-slate-900 dark:text-white">BAICS-2024-1234</p>
                                </div>
                                <div>
                                    <p class="text-xs text-slate-500">Date & Time</p>
                                    <p class="font-bold text-slate-900 dark:text-white"><%= new Date().toLocaleString() %></p>
                                </div>
                                <div>
                                    <p class="text-xs text-slate-500">Survey Type</p>
                                    <p class="font-bold text-primary">Institutional-Wide</p>
                                </div>
                                <div>
                                    <p class="text-xs text-slate-500">Department</p>
                                    <p class="font-bold text-slate-900 dark:text-white"><%= user.department %></p>
                                </div>
                            </div>
                        </div>

                        <!-- Next Steps -->
                        <div class="mb-8">
                            <h2 class="text-sm font-bold text-slate-900 dark:text-white mb-3">What happens next?</h2>
                            <ul class="text-xs text-slate-500 space-y-2">
                                <li>✓ Your responses will be reviewed by the administration team</li>
                                <li>✓ You'll receive notifications about any follow-up actions</li>
                                <li>✓ You can view your submission in the Submission History</li>
                            </ul>
                        </div>

                        <!-- Action Buttons -->
                        <div class="flex flex-col sm:flex-row gap-3 justify-center">
                            <a href="/office-head/my-surveys" class="px-6 py-3 bg-primary hover:bg-primary/90 text-white rounded-lg text-sm font-bold transition-colors shadow-lg shadow-primary/20">
                                Return to My Surveys
                            </a>
                            <a href="/office-head/submission-history" class="px-6 py-3 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                                View Submission History
                            </a>
                        </div>

                        <!-- Download Option -->
                        <div class="mt-6 pt-6 border-t border-slate-200 dark:border-slate-800">
                            <a href="#" class="text-primary hover:text-primary/70 text-xs font-medium flex items-center justify-center gap-1">
                                <span class="material-symbols-outlined text-sm">download</span>
                                Download Receipt (PDF)
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <%- include('../partials/scripts') %>
</body>
</html>