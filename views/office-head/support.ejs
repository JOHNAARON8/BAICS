<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Help & Support' }) %>
    <style>
        .faq-item {
            transition: all 0.3s ease;
        }
        .faq-item:hover {
            background-color: rgba(29, 62, 139, 0.02);
        }
        .support-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .support-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100">
    <!-- Mobile Menu Overlay -->
    <div id="mobileMenuOverlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden transition-opacity"></div>

    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <%- include('../partials/sidebar', { 
            role: 'office-head', 
            currentPage: 'support',
            user: user 
        }) %>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col min-w-0 h-screen overflow-hidden bg-background-light dark:bg-background-dark">
            <!-- Header -->
            <%- include('../partials/header', { 
                role: 'office-head', 
                pageTitle: 'Help & Support',
                user: user 
            }) %>

            <!-- Scrollable Content Area -->
            <div class="flex-1 overflow-y-auto custom-scrollbar">
                <div class="max-w-6xl mx-auto px-4 lg:px-6 py-6 lg:py-8">
                    <!-- Header Section -->
                    <div class="mb-8">
                        <h2 class="text-2xl lg:text-3xl font-black text-slate-900 dark:text-white tracking-tight">How can we help you?</h2>
                        <p class="text-sm lg:text-base text-slate-500 dark:text-slate-400 mt-1">Search for guides, FAQs, or contact our support team.</p>
                    </div>

                    <!-- Search Bar -->
                    <div class="mb-8">
                        <div class="relative max-w-2xl">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                            <input type="text" placeholder="Search for help articles, guides, FAQs..." 
                                   class="w-full pl-12 pr-4 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all">
                        </div>
                    </div>

                    <!-- Quick Support Cards -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 lg:gap-6 mb-8">
                        <div class="support-card bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 text-center cursor-pointer hover:border-primary/30">
                            <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                                <span class="material-symbols-outlined text-primary">help</span>
                            </div>
                            <h3 class="font-bold text-slate-900 dark:text-white mb-2">FAQs</h3>
                            <p class="text-xs text-slate-500">Find answers to commonly asked questions</p>
                        </div>
                        
                        <div class="support-card bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 text-center cursor-pointer hover:border-primary/30">
                            <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                                <span class="material-symbols-outlined text-primary">description</span>
                            </div>
                            <h3 class="font-bold text-slate-900 dark:text-white mb-2">Guides</h3>
                            <p class="text-xs text-slate-500">Step-by-step tutorials and documentation</p>
                        </div>
                        
                        <div class="support-card bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 text-center cursor-pointer hover:border-primary/30">
                            <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                                <span class="material-symbols-outlined text-primary">support_agent</span>
                            </div>
                            <h3 class="font-bold text-slate-900 dark:text-white mb-2">Contact Support</h3>
                            <p class="text-xs text-slate-500">Get help from our support team</p>
                        </div>
                    </div>

                    <!-- FAQ Section -->
                    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden mb-8">
                        <div class="p-6 border-b border-slate-200 dark:border-slate-800">
                            <h3 class="text-lg font-bold text-slate-900 dark:text-white">Frequently Asked Questions</h3>
                        </div>
                        
                        <div class="divide-y divide-slate-200 dark:divide-slate-800">
                            <!-- FAQ 1 -->
                            <div class="faq-item p-6">
                                <button onclick="toggleFAQ(1)" class="w-full flex items-center justify-between text-left">
                                    <span class="font-bold text-slate-900 dark:text-white">How do I start a new survey?</span>
                                    <span id="faq-icon-1" class="material-symbols-outlined text-primary transition-transform">expand_more</span>
                                </button>
                                <div id="faq-answer-1" class="hidden mt-4 text-sm text-slate-600 dark:text-slate-400">
                                    To start a new survey, navigate to "My Surveys" from the sidebar menu. You'll see a list of assigned surveys. Click the "Start Survey" button on any survey card to begin. The survey will open in a new form where you can answer questions and upload supporting documents.
                                </div>
                            </div>
                            
                            <!-- FAQ 2 -->
                            <div class="faq-item p-6">
                                <button onclick="toggleFAQ(2)" class="w-full flex items-center justify-between text-left">
                                    <span class="font-bold text-slate-900 dark:text-white">What happens if I answer "No" to a question?</span>
                                    <span id="faq-icon-2" class="material-symbols-outlined text-primary transition-transform">expand_more</span>
                                </button>
                                <div id="faq-answer-2" class="hidden mt-4 text-sm text-slate-600 dark:text-slate-400">
                                    When you answer "No" to any question, a comment box will appear where you must provide an explanation or remarks. You also have the option to upload supporting documents (PDF, DOC, DOCX, JPG, PNG) to provide evidence or additional context for your answer.
                                </div>
                            </div>
                            
                            <!-- FAQ 3 -->
                            <div class="faq-item p-6">
                                <button onclick="toggleFAQ(3)" class="w-full flex items-center justify-between text-left">
                                    <span class="font-bold text-slate-900 dark:text-white">Can I save my progress and continue later?</span>
                                    <span id="faq-icon-3" class="material-symbols-outlined text-primary transition-transform">expand_more</span>
                                </button>
                                <div id="faq-answer-3" class="hidden mt-4 text-sm text-slate-600 dark:text-slate-400">
                                    Yes, you can save your progress at any time by clicking the "Save as Draft" button at the bottom of the survey form. Your answers will be saved, and you can continue from where you left off by clicking "Continue Survey" on the survey card in "My Surveys" page.
                                </div>
                            </div>
                            
                            <!-- FAQ 4 -->
                            <div class="faq-item p-6">
                                <button onclick="toggleFAQ(4)" class="w-full flex items-center justify-between text-left">
                                    <span class="font-bold text-slate-900 dark:text-white">What file types are accepted for uploads?</span>
                                    <span id="faq-icon-4" class="material-symbols-outlined text-primary transition-transform">expand_more</span>
                                </button>
                                <div id="faq-answer-4" class="hidden mt-4 text-sm text-slate-600 dark:text-slate-400">
                                    The system accepts the following file types: PDF (.pdf), Word Documents (.doc, .docx), and Images (.jpg, .jpeg, .png). Each file must not exceed 10MB in size. You can upload multiple files per question.
                                </div>
                            </div>
                            
                            <!-- FAQ 5 -->
                            <div class="faq-item p-6">
                                <button onclick="toggleFAQ(5)" class="w-full flex items-center justify-between text-left">
                                    <span class="font-bold text-slate-900 dark:text-white">How do I view my submitted surveys?</span>
                                    <span id="faq-icon-5" class="material-symbols-outlined text-primary transition-transform">expand_more</span>
                                </button>
                                <div id="faq-answer-5" class="hidden mt-4 text-sm text-slate-600 dark:text-slate-400">
                                    Submitted surveys can be viewed in two ways: 1) In "My Surveys" page, click on the "Completed" tab to see all completed surveys, or 2) Go to "Submission History" from the sidebar to see a complete history of all your submissions.
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Contact Support Section -->
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <!-- Contact Form -->
                        <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6">
                            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Contact Support Team</h3>
                            
                            <form class="space-y-4">
                                <div>
                                    <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Subject</label>
                                    <input type="text" class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors" 
                                           placeholder="Brief description of your issue">
                                </div>
                                
                                <div>
                                    <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Category</label>
                                    <select class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors">
                                        <option>Technical Issue</option>
                                        <option>Survey Question</option>
                                        <option>Account Access</option>
                                        <option>Document Upload</option>
                                        <option>Other</option>
                                    </select>
                                </div>
                                
                                <div>
                                    <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Message</label>
                                    <textarea rows="4" class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors" 
                                              placeholder="Describe your issue in detail..."></textarea>
                                </div>
                                
                                <div>
                                    <label class="flex items-center gap-2 cursor-pointer">
                                        <input type="checkbox" class="w-4 h-4 text-primary border-slate-300 rounded focus:ring-primary/20">
                                        <span class="text-sm text-slate-600 dark:text-slate-400">Send me a copy of this message</span>
                                    </label>
                                </div>
                                
                                <button type="submit" class="w-full px-6 py-3 bg-primary hover:bg-primary/90 text-white rounded-lg text-sm font-bold transition-colors shadow-lg shadow-primary/20">
                                    Submit Ticket
                                </button>
                            </form>
                        </div>

                        <!-- Support Information -->
                        <div class="space-y-6">
                            <!-- Quick Contact -->
                            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6">
                                <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Quick Contact</h3>
                                
                                <div class="space-y-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center text-primary">
                                            <span class="material-symbols-outlined">mail</span>
                                        </div>
                                        <div>
                                            <p class="text-xs text-slate-500">Email</p>
                                            <p class="text-sm font-bold">support@baics.gov.ph</p>
                                        </div>
                                    </div>
                                    
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center text-primary">
                                            <span class="material-symbols-outlined">call</span>
                                        </div>
                                        <div>
                                            <p class="text-xs text-slate-500">Hotline</p>
                                            <p class="text-sm font-bold">(02) 1234 5678</p>
                                        </div>
                                    </div>
                                    
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center text-primary">
                                            <span class="material-symbols-outlined">schedule</span>
                                        </div>
                                        <div>
                                            <p class="text-xs text-slate-500">Support Hours</p>
                                            <p class="text-sm font-bold">Mon-Fri, 8:00 AM - 5:00 PM</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- System Status -->
                            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6">
                                <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-4">System Status</h3>
                                
                                <div class="space-y-3">
                                    <div class="flex items-center justify-between">
                                        <span class="text-sm">Survey Portal</span>
                                        <span class="flex items-center gap-1 text-emerald-600 text-sm">
                                            <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                                            Operational
                                        </span>
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-sm">File Upload Service</span>
                                        <span class="flex items-center gap-1 text-emerald-600 text-sm">
                                            <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                                            Operational
                                        </span>
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-sm">Database</span>
                                        <span class="flex items-center gap-1 text-emerald-600 text-sm">
                                            <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                                            Operational
                                        </span>
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-sm">Authentication</span>
                                        <span class="flex items-center gap-1 text-emerald-600 text-sm">
                                            <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                                            Operational
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <!-- Response Time -->
                            <div class="bg-gradient-to-br from-primary to-primary/80 rounded-xl p-6 text-white">
                                <h3 class="text-lg font-bold mb-2">Average Response Time</h3>
                                <p class="text-white/80 text-sm mb-4">Our support team typically responds within:</p>
                                <div class="grid grid-cols-3 gap-4 text-center">
                                    <div>
                                        <div class="text-2xl font-black">2</div>
                                        <div class="text-[10px] uppercase text-white/60">Hours</div>
                                    </div>
                                    <div>
                                        <div class="text-2xl font-black">24/7</div>
                                        <div class="text-[10px] uppercase text-white/60">Support</div>
                                    </div>
                                    <div>
                                        <div class="text-2xl font-black">98%</div>
                                        <div class="text-[10px] uppercase text-white/60">Satisfaction</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Help Guides Section -->
                    <div class="mt-8">
                        <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Popular Help Guides</h3>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                            <a href="#" class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-4 hover:border-primary/30 transition-colors">
                                <div class="flex items-start gap-3">
                                    <span class="material-symbols-outlined text-primary">assignment</span>
                                    <div>
                                        <h4 class="font-bold text-sm mb-1">Completing Your First Survey</h4>
                                        <p class="text-xs text-slate-500">Step-by-step guide to answering surveys</p>
                                    </div>
                                </div>
                            </a>
                            
                            <a href="#" class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-4 hover:border-primary/30 transition-colors">
                                <div class="flex items-start gap-3">
                                    <span class="material-symbols-outlined text-primary">upload_file</span>
                                    <div>
                                        <h4 class="font-bold text-sm mb-1">Uploading Documents</h4>
                                        <p class="text-xs text-slate-500">How to attach supporting files</p>
                                    </div>
                                </div>
                            </a>
                            
                            <a href="#" class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-4 hover:border-primary/30 transition-colors">
                                <div class="flex items-start gap-3">
                                    <span class="material-symbols-outlined text-primary">history</span>
                                    <div>
                                        <h4 class="font-bold text-sm mb-1">Tracking Submissions</h4>
                                        <p class="text-xs text-slate-500">View your survey history and status</p>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- FAQ Toggle Script -->
    <script>
        function toggleFAQ(id) {
            const answer = document.getElementById(`faq-answer-${id}`);
            const icon = document.getElementById(`faq-icon-${id}`);
            
            if (answer.classList.contains('hidden')) {
                answer.classList.remove('hidden');
                icon.style.transform = 'rotate(180deg)';
            } else {
                answer.classList.add('hidden');
                icon.style.transform = 'rotate(0deg)';
            }
        }
    </script>

    <!-- Scripts -->
    <%- include('../partials/scripts') %>
</body>
</html>