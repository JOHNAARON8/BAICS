<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Office Head Dashboard' }) %>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100">
    <!-- Mobile Menu Overlay -->
    <div id="mobileMenuOverlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden transition-opacity"></div>

    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <%- include('../partials/sidebar', { 
            role: 'office-head', 
            currentPage: 'dashboard',
            user: user 
        }) %>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col min-w-0 h-screen overflow-hidden bg-background-light dark:bg-background-dark">
            <!-- Header -->
            <%- include('../partials/header', { 
                role: 'office-head', 
                pageTitle: 'Dashboard',
                user: user 
            }) %>

            <!-- Scrollable Content Area -->
            <div class="flex-1 overflow-y-auto custom-scrollbar">
                <div class="p-4 lg:p-8">
                    <!-- Header Section -->
                    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-4 mb-6 lg:mb-8">
                        <div class="max-w-2xl">
                            <h2 class="text-2xl lg:text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Office Head Dashboard</h2>
                           <p class="text-sm lg:text-base text-slate-500 dark:text-slate-400 mt-2">Welcome back, <%= user.username %>. You have <span class="font-bold text-primary">3 surveys</span> requiring immediate attention today.</p>
                        </div>
                    </div>

                    <!-- Metrics Grid - Updated with office context -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6 mb-6 lg:mb-8">
                        <div class="bg-white dark:bg-slate-900 p-5 lg:p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                            <div class="flex justify-between items-start mb-3 lg:mb-4">
                                <p class="text-xs lg:text-sm font-medium text-slate-500">Assigned Surveys</p>
                                <span class="px-2 py-1 text-[10px] lg:text-xs font-medium bg-green-100 text-green-700 rounded-full">Institutional-Wide: 2</span>
                            </div>
                            <p class="text-2xl lg:text-3xl font-bold text-slate-900 dark:text-white">12</p>
                            <div class="mt-3 lg:mt-4 flex items-center justify-between text-[10px] lg:text-xs">
                                <span class="text-slate-400">Department-Specific: 1</span>
                                <span class="text-slate-400">Completed: 8</span>
                            </div>
                            <div class="mt-2 w-full bg-slate-100 dark:bg-slate-800 h-1.5 rounded-full overflow-hidden">
                                <div class="bg-primary h-full w-[65%] rounded-full"></div>
                            </div>
                        </div>
                        
                        <div class="bg-white dark:bg-slate-900 p-5 lg:p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                            <div class="flex justify-between items-start mb-3 lg:mb-4">
                                <p class="text-xs lg:text-sm font-medium text-slate-500">Pending Reviews</p>
                                <span class="px-2 py-1 text-[10px] lg:text-xs font-medium bg-red-100 text-red-700 rounded-full">Critical: 1</span>
                            </div>
                            <p class="text-2xl lg:text-3xl font-bold text-slate-900 dark:text-white">4</p>
                            <div class="mt-3 lg:mt-4 flex items-center justify-between text-[10px] lg:text-xs">
                                <span class="text-slate-400">High Priority: 2</span>
                                <span class="text-slate-400">Normal: 1</span>
                            </div>
                            <div class="mt-2 w-full bg-slate-100 dark:bg-slate-800 h-1.5 rounded-full overflow-hidden">
                                <div class="bg-amber-500 h-full w-[35%] rounded-full"></div>
                            </div>
                        </div>
                        
                        <div class="bg-white dark:bg-slate-900 p-5 lg:p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm sm:col-span-2 lg:col-span-1">
                            <div class="flex justify-between items-start mb-3 lg:mb-4">
                                <p class="text-xs lg:text-sm font-medium text-slate-500">Completion Rate</p>
                                <span class="px-2 py-1 text-[10px] lg:text-xs font-medium bg-blue-100 text-blue-700 rounded-full">+12%</span>
                            </div>
                            <p class="text-2xl lg:text-3xl font-bold text-slate-900 dark:text-white">75%</p>
                            <div class="mt-3 lg:mt-4 flex items-center justify-between text-[10px] lg:text-xs">
                                <span class="text-slate-400">Institutional: 70%</span>
                                <span class="text-slate-400">Dept-Specific: 85%</span>
                            </div>
                            <div class="mt-2 w-full bg-slate-100 dark:bg-slate-800 h-1.5 rounded-full overflow-hidden">
                                <div class="bg-emerald-500 h-full w-[75%] rounded-full"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Survey Type Summary Cards -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 lg:gap-6 mb-6 lg:mb-8">
                        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/10 dark:to-indigo-900/10 border border-blue-200 dark:border-blue-800/30 rounded-xl p-4">
                            <div class="flex items-start justify-between">
                                <div class="flex items-center gap-3">
                                    <div class="size-10 rounded-lg bg-primary text-white flex items-center justify-center">
                                        <span class="material-symbols-outlined text-lg">account_balance</span>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-sm text-primary">Institutional-Wide Surveys</h3>
                                        <p class="text-xs text-slate-500">All 16 offices required</p>
                                    </div>
                                </div>
                                <span class="text-xs font-bold bg-primary/10 text-primary px-2 py-1 rounded">2 Active</span>
                            </div>
                            <div class="mt-3 flex items-center gap-4">
                                <div class="flex-1">
                                    <div class="flex justify-between text-[10px] mb-1">
                                        <span class="text-slate-500">Overall Progress</span>
                                        <span class="font-medium">12/16 completed</span>
                                    </div>
                                    <div class="w-full bg-slate-200 h-1.5 rounded-full overflow-hidden">
                                        <div class="bg-primary h-full rounded-full" style="width: 75%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="bg-gradient-to-br from-purple-50 to-violet-50 dark:from-purple-900/10 dark:to-violet-900/10 border border-purple-200 dark:border-purple-800/30 rounded-xl p-4">
                            <div class="flex items-start justify-between">
                                <div class="flex items-center gap-3">
                                    <div class="size-10 rounded-lg bg-purple-600 text-white flex items-center justify-center">
                                        <span class="material-symbols-outlined text-lg">domain</span>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-sm text-purple-700 dark:text-purple-400">Department-Specific Surveys</h3>
                                        <p class="text-xs text-slate-500"><%= user.department %> only</p>
                                    </div>
                                </div>
                                <span class="text-xs font-bold bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400 px-2 py-1 rounded">1 Active</span>
                            </div>
                            <div class="mt-3">
                                <div class="flex justify-between text-[10px] mb-1">
                                    <span class="text-slate-500">Your Progress</span>
                                    <span class="font-medium">Not started</span>
                                </div>
                                <div class="w-full bg-slate-200 h-1.5 rounded-full overflow-hidden">
                                    <div class="bg-purple-600 h-full rounded-full" style="width: 0%"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Main Grid - Task List and Right Sidebar -->
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
                        <!-- Task List (Left/Main) -->
                        <div class="lg:col-span-2 space-y-6">
                            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                                <div class="p-4 lg:p-6 border-b border-slate-100 dark:border-slate-800 flex justify-between items-center">
                                    <h2 class="text-base lg:text-lg font-bold">Active Assignments by Department</h2>
                                    <a class="text-xs lg:text-sm font-medium text-primary hover:underline" href="/office-head/my-surveys">View all</a>
                                </div>
                                <div class="divide-y divide-slate-100 dark:divide-slate-800">
                                    <!-- Task Item 1 - Institutional-Wide -->
                                    <div class="p-4 lg:p-6 flex flex-col sm:flex-row sm:items-center gap-4 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors group">
                                        <div class="size-10 lg:size-12 rounded-lg bg-primary/5 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all flex-shrink-0">
                                            <span class="material-symbols-outlined text-lg lg:text-xl">account_balance</span>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <div class="flex flex-wrap items-center gap-2 mb-1">
                                                <h3 class="font-semibold text-sm lg:text-base text-slate-900 dark:text-white truncate">Annual Institutional Risk Assessment</h3>
                                                <span class="px-2 py-0.5 bg-primary/10 text-primary text-[8px] lg:text-[10px] font-bold uppercase rounded">Institutional-Wide</span>
                                            </div>
                                            <p class="text-xs lg:text-sm text-slate-500">All 16 offices • 12 completed, 4 pending</p>
                                            <div class="mt-2 flex items-center gap-2">
                                                <div class="w-24 lg:w-32 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                                    <div class="bg-primary h-full rounded-full" style="width: 75%"></div>
                                                </div>
                                                <span class="text-[10px] lg:text-xs text-slate-400">Your office: <span class="text-emerald-600 font-medium">Completed</span></span>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-3 sm:text-right">
                                            <div>
                                                <span class="inline-block px-2 py-1 rounded-full text-[8px] lg:text-[10px] font-semibold bg-blue-100 text-blue-700 mb-1 whitespace-nowrap">Due in 2 days</span>
                                            </div>
                                            <a href="#" class="p-1.5 text-slate-400 hover:text-primary rounded-full hover:bg-slate-100">
                                                <span class="material-symbols-outlined text-lg">chevron_right</span>
                                            </a>
                                        </div>
                                    </div>

                                    <!-- Task Item 2 - Department-Specific -->
                                    <div class="p-4 lg:p-6 flex flex-col sm:flex-row sm:items-center gap-4 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors group">
                                        <div class="size-10 lg:size-12 rounded-lg bg-purple-100 text-purple-600 flex items-center justify-center group-hover:bg-purple-600 group-hover:text-white transition-all flex-shrink-0">
                                            <span class="material-symbols-outlined text-lg lg:text-xl">domain</span>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <div class="flex flex-wrap items-center gap-2 mb-1">
                                                <h3 class="font-semibold text-sm lg:text-base text-slate-900 dark:text-white truncate"><%= user.department %> Operational Review</h3>
                                                <span class="px-2 py-0.5 bg-purple-100 text-purple-700 text-[8px] lg:text-[10px] font-bold uppercase rounded">Department-Specific</span>
                                            </div>
                                            <p class="text-xs lg:text-sm text-slate-500"><%= user.department %> only • Your office only</p>
                                            <div class="mt-2 flex items-center gap-2">
                                                <div class="w-24 lg:w-32 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                                    <div class="bg-purple-600 h-full rounded-full" style="width: 0%"></div>
                                                </div>
                                                <span class="text-[10px] lg:text-xs text-slate-400">Not started</span>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-3 sm:text-right">
                                            <div>
                                                <span class="inline-block px-2 py-1 rounded-full text-[8px] lg:text-[10px] font-semibold bg-amber-100 text-amber-700 mb-1 whitespace-nowrap">Priority</span>
                                                <p class="text-[10px] lg:text-xs text-slate-400">Due in 5 days</p>
                                            </div>
                                            <a href="/office-head/my-surveys" class="p-1.5 text-slate-400 hover:text-primary rounded-full hover:bg-slate-100">
                                                <span class="material-symbols-outlined text-lg">chevron_right</span>
                                            </a>
                                        </div>
                                    </div>

                                    <!-- Task Item 3 - Institutional-Wide -->
                                    <div class="p-4 lg:p-6 flex flex-col sm:flex-row sm:items-center gap-4 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors group">
                                        <div class="size-10 lg:size-12 rounded-lg bg-primary/5 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all flex-shrink-0">
                                            <span class="material-symbols-outlined text-lg lg:text-xl">account_balance</span>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <div class="flex flex-wrap items-center gap-2 mb-1">
                                                <h3 class="font-semibold text-sm lg:text-base text-slate-900 dark:text-white truncate">Internal Control Self-Assessment</h3>
                                                <span class="px-2 py-0.5 bg-primary/10 text-primary text-[8px] lg:text-[10px] font-bold uppercase rounded">Institutional-Wide</span>
                                            </div>
                                            <p class="text-xs lg:text-sm text-slate-500">All 16 offices • 8 completed, 8 pending</p>
                                            <div class="mt-2 flex items-center gap-2">
                                                <div class="w-24 lg:w-32 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                                    <div class="bg-primary h-full rounded-full" style="width: 50%"></div>
                                                </div>
                                                <span class="text-[10px] lg:text-xs text-slate-400">Your office: <span class="text-amber-600 font-medium">In Progress (65%)</span></span>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-3 sm:text-right">
                                            <div>
                                                <span class="inline-block px-2 py-1 rounded-full text-[8px] lg:text-[10px] font-semibold bg-red-100 text-red-700 mb-1 whitespace-nowrap">Critical</span>
                                                <p class="text-[10px] lg:text-xs text-slate-400">Due in 5 hours</p>
                                            </div>
                                            <a href="#" class="p-1.5 text-slate-400 hover:text-primary rounded-full hover:bg-slate-100">
                                                <span class="material-symbols-outlined text-lg">chevron_right</span>
                                            </a>
                                        </div>
                                    </div>

                                    <!-- Task Item 4 - Pending Office -->
                                    <div class="p-4 lg:p-6 flex flex-col sm:flex-row sm:items-center gap-4 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors group bg-amber-50/30 dark:bg-amber-900/5">
                                        <div class="size-10 lg:size-12 rounded-lg bg-amber-100 text-amber-600 flex items-center justify-center group-hover:bg-amber-600 group-hover:text-white transition-all flex-shrink-0">
                                            <span class="material-symbols-outlined text-lg lg:text-xl">pending_actions</span>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <div class="flex flex-wrap items-center gap-2 mb-1">
                                                <h3 class="font-semibold text-sm lg:text-base text-slate-900 dark:text-white truncate">Property & Supply Asset Review</h3>
                                                <span class="px-2 py-0.5 bg-amber-100 text-amber-700 text-[8px] lg:text-[10px] font-bold uppercase rounded">Pending</span>
                                            </div>
                                            <p class="text-xs lg:text-sm text-slate-500">Property & Supply Department • Awaiting response</p>
                                            <div class="mt-2 flex items-center gap-2">
                                                <span class="text-[10px] lg:text-xs text-amber-600 font-medium">Reminder sent 2 days ago</span>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-3 sm:text-right">
                                            <div>
                                                <span class="inline-block px-2 py-1 rounded-full text-[8px] lg:text-[10px] font-semibold bg-amber-100 text-amber-700 mb-1 whitespace-nowrap">Overdue</span>
                                            </div>
                                            <a href="#" class="p-1.5 text-slate-400 hover:text-primary rounded-full hover:bg-slate-100">
                                                <span class="material-symbols-outlined text-lg">chevron_right</span>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Pending Offices Summary -->
                            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-4 lg:p-6">
                                <h3 class="text-sm lg:text-base font-bold mb-3">Pending Offices - Institutional-Wide Surveys</h3>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                    <div class="flex items-center gap-2 p-2 bg-amber-50 dark:bg-amber-900/10 rounded-lg">
                                        <span class="size-2 rounded-full bg-amber-500"></span>
                                        <span class="text-xs">Property & Supply</span>
                                    </div>
                                    <div class="flex items-center gap-2 p-2 bg-amber-50 dark:bg-amber-900/10 rounded-lg">
                                        <span class="size-2 rounded-full bg-amber-500"></span>
                                        <span class="text-xs">IT Department</span>
                                    </div>
                                    <div class="flex items-center gap-2 p-2 bg-amber-50 dark:bg-amber-900/10 rounded-lg">
                                        <span class="size-2 rounded-full bg-amber-500"></span>
                                        <span class="text-xs">Procurement Dept</span>
                                    </div>
                                    <div class="flex items-center gap-2 p-2 bg-amber-50 dark:bg-amber-900/10 rounded-lg">
                                        <span class="size-2 rounded-full bg-amber-500"></span>
                                        <span class="text-xs">Accounts Receivable</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Sidebar Content (Right) -->
                        <div class="space-y-6">
                            <!-- Deadline Countdown -->
                            <div class="bg-primary rounded-xl p-5 lg:p-6 text-white shadow-lg shadow-primary/20">
                                <h3 class="text-xs lg:text-sm font-semibold uppercase tracking-wider text-white/70 mb-3 lg:mb-4">Next Deadline</h3>
                                <p class="text-base lg:text-lg font-bold mb-3 lg:mb-4">Internal Control Self-Assessment</p>
                                <div class="grid grid-cols-4 gap-1 lg:gap-2">
                                    <div class="bg-white/10 rounded-lg p-2 text-center">
                                        <span class="block text-lg lg:text-xl font-bold">00</span>
                                        <span class="text-[8px] lg:text-[10px] uppercase opacity-60">Days</span>
                                    </div>
                                    <div class="bg-white/10 rounded-lg p-2 text-center">
                                        <span class="block text-lg lg:text-xl font-bold">05</span>
                                        <span class="text-[8px] lg:text-[10px] uppercase opacity-60">Hours</span>
                                    </div>
                                    <div class="bg-white/10 rounded-lg p-2 text-center">
                                        <span class="block text-lg lg:text-xl font-bold">42</span>
                                        <span class="text-[8px] lg:text-[10px] uppercase opacity-60">Mins</span>
                                    </div>
                                    <div class="bg-white/10 rounded-lg p-2 text-center">
                                        <span class="block text-lg lg:text-xl font-bold">18</span>
                                        <span class="text-[8px] lg:text-[10px] uppercase opacity-60">Secs</span>
                                    </div>
                                </div>
                                <a href="/office-head/my-surveys" class="block w-full mt-4 lg:mt-6 py-2.5 bg-white text-primary rounded-lg text-xs lg:text-sm font-bold hover:bg-slate-50 transition-colors text-center">
                                    Continue Survey
                                </a>
                            </div>

                            <!-- Recent Activity -->
                            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-5 lg:p-6">
                                <h3 class="text-sm lg:text-base font-bold mb-4">Recent Activity</h3>
                                <div class="space-y-4">
                                    <div class="flex gap-3">
                                        <div class="size-2 mt-1.5 rounded-full bg-green-500 shrink-0"></div>
                                        <div>
                                            <p class="text-xs lg:text-sm font-medium">Accounting Department completed survey</p>
                                            <p class="text-[10px] lg:text-xs text-slate-400">Institutional Risk Assessment • 2h ago</p>
                                        </div>
                                    </div>
                                    <div class="flex gap-3">
                                        <div class="size-2 mt-1.5 rounded-full bg-primary shrink-0"></div>
                                        <div>
                                            <p class="text-xs lg:text-sm font-medium">Department-Specific Survey assigned</p>
                                            <p class="text-[10px] lg:text-xs text-slate-400"><%= user.department %> Review • 5h ago</p>
                                        </div>
                                    </div>
                                    <div class="flex gap-3">
                                        <div class="size-2 mt-1.5 rounded-full bg-amber-500 shrink-0"></div>
                                        <div>
                                            <p class="text-xs lg:text-sm font-medium">Reminder sent to Property & Supply</p>
                                            <p class="text-[10px] lg:text-xs text-slate-400">Asset Review • Yesterday</p>
                                        </div>
                                    </div>
                                    <div class="flex gap-3">
                                        <div class="size-2 mt-1.5 rounded-full bg-blue-500 shrink-0"></div>
                                        <div>
                                            <p class="text-xs lg:text-sm font-medium">Treasurer's Office submitted response</p>
                                            <p class="text-[10px] lg:text-xs text-slate-400">Cash Management • Yesterday</p>
                                        </div>
                                    </div>
                                </div>
                                <button class="w-full mt-4 lg:mt-6 py-2 border border-slate-200 dark:border-slate-700 rounded-lg text-[10px] lg:text-xs font-medium text-slate-500 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                                    View Full Log
                                </button>
                            </div>
                            
                            <!-- Office Stats -->
                            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-5 lg:p-6">
                                <h3 class="text-sm lg:text-base font-bold mb-3">Office Completion Stats</h3>
                                <div class="space-y-3">
                                    <div>
                                        <div class="flex justify-between text-[10px] lg:text-xs mb-1">
                                            <span class="text-slate-500">Completed Offices</span>
                                            <span class="font-medium">12/16</span>
                                        </div>
                                        <div class="w-full bg-slate-100 h-1.5 rounded-full overflow-hidden">
                                            <div class="bg-emerald-500 h-full rounded-full" style="width: 75%"></div>
                                        </div>
                                    </div>
                                    <div>
                                        <div class="flex justify-between text-[10px] lg:text-xs mb-1">
                                            <span class="text-slate-500">Pending Offices</span>
                                            <span class="font-medium">4</span>
                                        </div>
                                        <div class="w-full bg-slate-100 h-1.5 rounded-full overflow-hidden">
                                            <div class="bg-amber-500 h-full rounded-full" style="width: 25%"></div>
                                        </div>
                                    </div>
                                    <div class="pt-3 mt-3 border-t border-slate-100 dark:border-slate-800">
                                        <p class="text-[10px] lg:text-xs text-slate-400 mb-2">Pending offices:</p>
                                        <div class="space-y-1">
                                            <p class="text-[10px] lg:text-xs">• Property & Supply</p>
                                            <p class="text-[10px] lg:text-xs">• IT Department</p>
                                            <p class="text-[10px] lg:text-xs">• Procurement Dept</p>
