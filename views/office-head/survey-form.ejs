    <!-- JavaScript for Interactive Features -->
    <script>
        // Toggle comment box based on Yes/No selection
        function toggleComment(questionId, show) {
            const commentBox = document.getElementById(`comment-${questionId}`);
            if (show) {
                commentBox.classList.remove('hidden');
                // Make textarea required
                const textarea = commentBox.querySelector('textarea');
                if (textarea) textarea.required = true;
            } else {
                commentBox.classList.add('hidden');
                // Remove required attribute
                const textarea = commentBox.querySelector('textarea');
                if (textarea) textarea.required = false;
            }
        }

        // Handle file upload for each question
        document.querySelectorAll('input[type="file"]').forEach(input => {
            input.addEventListener('change', function(e) {
                const questionId = this.id.replace('file-', '');
                const fileList = document.getElementById(`fileList-${questionId}`);
                fileList.innerHTML = '';
                
                Array.from(this.files).forEach(file => {
                    const fileItem = document.createElement('div');
                    fileItem.className = 'flex items-center justify-between bg-white dark:bg-slate-800 p-2 rounded-lg text-xs';
                    fileItem.innerHTML = `
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-slate-400 text-sm">description</span>
                            <span class="text-slate-600 dark:text-slate-400">${file.name}</span>
                            <span class="text-slate-400">(${(file.size / 1024).toFixed(1)} KB)</span>
                        </div>
                        <button type="button" onclick="removeFile('${questionId}', '${file.name}')" class="text-red-500 hover:text-red-700">
                            <span class="material-symbols-outlined text-sm">close</span>
                        </button>
                    `;
                    fileList.appendChild(fileItem);
                });
            });
        });

        // Remove file from upload list
        function removeFile(questionId, fileName) {
            const input = document.getElementById(`file-${questionId}`);
            const fileList = document.getElementById(`fileList-${questionId}`);
            
            // Create new FileList without the removed file (simplified - in production you'd handle this differently)
            fileList.innerHTML = '';
            
            // Reset input
            input.value = '';
        }

        // Drag and drop functionality
        document.querySelectorAll('.file-upload-area').forEach(area => {
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                area.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            ['dragenter', 'dragover'].forEach(eventName => {
                area.addEventListener(eventName, () => {
                    area.classList.add('dragover');
                });
            });

            ['dragleave', 'drop'].forEach(eventName => {
                area.addEventListener(eventName, () => {
                    area.classList.remove('dragover');
                });
            });

            area.addEventListener('drop', (e) => {
                const input = area.querySelector('input[type="file"]');
                const files = e.dataTransfer.files;
                input.files = files;
                
                // Trigger change event
                const event = new Event('change', { bubbles: true });
                input.dispatchEvent(event);
            });
        });

        // Save draft function
        function saveDraft() {
            // Collect form data
            const formData = new FormData(document.getElementById('surveyForm'));
            
            // Show success message (in production, send to server)
            alert('Draft saved successfully! You can continue later.');
        }

        // Submit survey function
        function submitSurvey() {
            // Check if all required fields are filled
            const requiredFields = document.querySelectorAll('[required]');
            let isValid = true;
            
            requiredFields.forEach(field => {
                if (!field.value) {
                    isValid = false;
                    field.classList.add('border-red-500');
                } else {
                    field.classList.remove('border-red-500');
                }
            });

            // Check if all questions are answered
            const questions = document.querySelectorAll('input[type="radio"]');
            const questionGroups = {};
            questions.forEach(q => {
                if (!questionGroups[q.name]) {
                    questionGroups[q.name] = false;
                }
                if (q.checked) {
                    questionGroups[q.name] = true;
                }
            });

            const allAnswered = Object.values(questionGroups).every(v => v === true);
            
            if (!allAnswered) {
                alert('Please answer all questions before submitting.');
                return;
            }

            if (!isValid) {
                alert('Please fill in all required comment fields for "No" answers.');
                return;
            }

            // If validation passes, redirect to confirmation page
            window.location.href = '/office-head/survey-confirmation';
        }

        // Initialize tooltips or other features
        document.addEventListener('DOMContentLoaded', function() {
            // Check for any pre-selected "No" answers on page load
            document.querySelectorAll('input[type="radio"][value="no"]:checked').forEach(radio => {
                const questionId = radio.name;
                toggleComment(questionId, true);
            });
        });
    </script>

    <!-- Scripts -->
    <%- include('../partials/scripts') %>
</body>
</html>