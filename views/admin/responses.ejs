                                                </div>
                                                <span class="text-[10px] lg:text-xs font-bold">100%</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <span class="inline-flex items-center px-2 py-0.5 lg:px-2.5 lg:py-0.5 rounded-full text-[10px] lg:text-xs font-bold bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400 whitespace-nowrap">Completed</span>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <button class="text-primary hover:text-primary/70 font-bold text-[10px] lg:text-xs uppercase whitespace-nowrap">View Details</button>
                                        </td>
                                    </tr>
                                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2 lg:gap-3">
                                                <div class="size-7 lg:size-8 rounded bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
                                                    <span class="material-symbols-outlined text-base lg:text-lg">account_balance</span>
                                                </div>
                                                <span class="text-xs lg:text-sm font-bold truncate max-w-[150px] lg:max-w-none">Finance & HR</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4 text-center">
                                            <span class="text-xs lg:text-sm font-bold text-emerald-600">Submitted</span>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2">
                                                <div class="flex-1 h-1.5 lg:h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden min-w-[80px] lg:min-w-[100px]">
                                                    <div class="h-full bg-emerald-500" style="width: 100%"></div>
                                                </div>
                                                <span class="text-[10px] lg:text-xs font-bold">100%</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <span class="inline-flex items-center px-2 py-0.5 lg:px-2.5 lg:py-0.5 rounded-full text-[10px] lg:text-xs font-bold bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400 whitespace-nowrap">Completed</span>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <button class="text-primary hover:text-primary/70 font-bold text-[10px] lg:text-xs uppercase whitespace-nowrap">View Details</button>
                                        </td>
                                    </tr>
                                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2 lg:gap-3">
                                                <div class="size-7 lg:size-8 rounded bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
                                                    <span class="material-symbols-outlined text-base lg:text-lg">science</span>
                                                </div>
                                                <span class="text-xs lg:text-sm font-bold truncate max-w-[150px] lg:max-w-none">Research Labs</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4 text-center">
                                            <span class="text-xs lg:text-sm font-bold text-amber-600">Pending</span>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2">
                                                <div class="flex-1 h-1.5 lg:h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden min-w-[80px] lg:min-w-[100px]">
                                                    <div class="h-full bg-amber-500" style="width: 0%"></div>
                                                </div>
                                                <span class="text-[10px] lg:text-xs font-bold">0%</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <span class="inline-flex items-center px-2 py-0.5 lg:px-2.5 lg:py-0.5 rounded-full text-[10px] lg:text-xs font-bold bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400 whitespace-nowrap">Awaiting</span>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <button class="text-primary hover:text-primary/70 font-bold text-[10px] lg:text-xs uppercase whitespace-nowrap">View Details</button>
                                        </td>
                                    </tr>
                                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2 lg:gap-3">
                                                <div class="size-7 lg:size-8 rounded bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
                                                    <span class="material-symbols-outlined text-base lg:text-lg">gavel</span>
                                                </div>
                                                <span class="text-xs lg:text-sm font-bold truncate max-w-[150px] lg:max-w-none">Legal Affairs</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4 text-center">
                                            <span class="text-xs lg:text-sm font-bold text-emerald-600">Submitted</span>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2">
                                                <div class="flex-1 h-1.5 lg:h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden min-w-[80px] lg:min-w-[100px]">
                                                    <div class="h-full bg-emerald-500" style="width: 100%"></div>
                                                </div>
                                                <span class="text-[10px] lg:text-xs font-bold">100%</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <span class="inline-flex items-center px-2 py-0.5 lg:px-2.5 lg:py-0.5 rounded-full text-[10px] lg:text-xs font-bold bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400 whitespace-nowrap">Completed</span>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <button class="text-primary hover:text-primary/70 font-bold text-[10px] lg:text-xs uppercase whitespace-nowrap">View Details</button>
                                        </td>
                                    </tr>
                                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2 lg:gap-3">
                                                <div class="size-7 lg:size-8 rounded bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
                                                    <span class="material-symbols-outlined text-base lg:text-lg">computer</span>
                                                </div>
                                                <span class="text-xs lg:text-sm font-bold truncate max-w-[150px] lg:max-w-none">IT Department</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4 text-center">
                                            <span class="text-xs lg:text-sm font-bold text-amber-600">Pending</span>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2">
                                                <div class="flex-1 h-1.5 lg:h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden min-w-[80px] lg:min-w-[100px]">
                                                    <div class="h-full bg-amber-500" style="width: 0%"></div>
                                                </div>
                                                <span class="text-[10px] lg:text-xs font-bold">0%</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <span class="inline-flex items-center px-2 py-0.5 lg:px-2.5 lg:py-0.5 rounded-full text-[10px] lg:text-xs font-bold bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400 whitespace-nowrap">Awaiting</span>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <button class="text-primary hover:text-primary/70 font-bold text-[10px] lg:text-xs uppercase whitespace-nowrap">View Details</button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination - Responsive -->
                        <div class="bg-slate-50 dark:bg-slate-800/50 px-4 lg:px-6 py-3 lg:py-4 flex flex-col sm:flex-row items-center justify-between gap-3 border-t border-slate-200 dark:border-slate-800">
                            <p class="text-[10px] lg:text-xs text-slate-500 font-medium tracking-wide">Showing 1-5 of 24 Offices</p>
                            <div class="flex items-center gap-1 lg:gap-2">
                                <button class="size-7 lg:size-8 flex items-center justify-center rounded bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 text-slate-400 cursor-not-allowed">
                                    <span class="material-symbols-outlined text-sm">chevron_left</span>
                                </button>
                                <button class="size-7 lg:size-8 flex items-center justify-center rounded bg-primary text-white font-bold text-xs">1</button>
                                <button class="size-7 lg:size-8 flex items-center justify-center rounded bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 font-bold text-xs hover:border-primary transition-colors">2</button>
                                <button class="size-7 lg:size-8 flex items-center justify-center rounded bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 font-bold text-xs hover:border-primary transition-colors">3</button>
                                <button class="size-7 lg:size-8 flex items-center justify-center rounded bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 hover:border-primary transition-colors">
                                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Summary Card - Optional -->
                    <div class="bg-primary/5 dark:bg-primary/10 rounded-xl p-4 lg:p-6 border border-primary/20 dark:border-primary/30">
                        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                            <div class="flex items-center gap-3">
                                <div class="size-10 lg:size-12 bg-primary/20 rounded-lg flex items-center justify-center text-primary">
                                    <span class="material-symbols-outlined text-xl lg:text-2xl">info</span>
                                </div>
                                <div>
                                    <h3 class="text-sm lg:text-base font-bold text-primary">Response Summary</h3>
                                    <p class="text-xs lg:text-sm text-slate-600 dark:text-slate-400">18 of 24 department heads have submitted their responses</p>
                                </div>
                            </div>
                            <div class="text-2xl lg:text-3xl font-black text-primary">75%</div>
                        </div>
                    </div>
