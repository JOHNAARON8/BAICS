                                <div class="size-8 lg:size-10 bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 dark:text-emerald-400 rounded-lg flex items-center justify-center">
                                    <span class="material-symbols-outlined text-lg lg:text-xl">checklist</span>
                                </div>
                            </div>
                            <div class="flex items-end gap-2 lg:gap-3">
