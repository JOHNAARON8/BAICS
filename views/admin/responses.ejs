                                <span class="text-xs lg:text-sm font-medium text-slate-500 dark:text-slate-400">Total Offices</span>
                                <div class="size-8 lg:size-10 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 rounded-lg flex items-center justify-center">
                                    <span class="material-symbols-outlined text-lg lg:text-xl">business</span>
                                </div>
                            </div>
                            <div class="flex items-end gap-2 lg:gap-3">
                                <p class="text-2xl lg:text-3xl font-black text-slate-900 dark:text-white">24</p>
                                <span class="text-emerald-600 font-bold text-xs lg:text-sm mb-1 flex items-center">
                                    <span class="material-symbols-outlined text-xs lg:text-sm">trending_up</span>
                                    +2
                                </span>
                            </div>
                        </div>

                        <div class="bg-white dark:bg-slate-900 p-4 lg:p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                            <div class="flex items-center justify-between mb-3 lg:mb-4">
