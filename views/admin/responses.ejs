                        </div>
                        <button class="w-full sm:w-auto flex items-center justify-center gap-2 px-4 lg:px-6 py-2.5 lg:py-2.5 bg-primary text-white rounded-lg font-bold text-sm shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all">
