<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Help & Support' }) %>
</head>

<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100">

    <!-- Mobile Menu Overlay -->
    <div id="mobileMenuOverlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden transition-opacity"></div>

    <div class="flex h-screen overflow-hidden">

        <!-- Sidebar -->
        <%- include('../partials/sidebar', { 
            role: 'admin', 
            currentPage: 'help-support',
            user: user 
        }) %>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col min-w-0 h-screen overflow-hidden bg-background-light dark:bg-background-dark">

            <!-- Header -->
            <%- include('../partials/header', { 
                role: 'admin', 
                pageTitle: 'Help & Support',
                user: user 
            }) %>

            <!-- Scrollable Content Area -->
            <div class="flex-1 overflow-y-auto custom-scrollbar">
                <div class="p-4 lg:p-8">

                    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-8 text-center">

                        <span class="material-symbols-outlined text-6xl text-primary mb-4">
                            support_agent
                        </span>

                        <h2 class="text-2xl font-bold mb-2">Help & Support</h2>

                        <p class="text-slate-500 mb-6">
                            If you encounter problems or need assistance using the system, you can contact support or check the user guide below.
                        </p>

                        <div class="space-y-4">
                            <p class="text-sm text-slate-600 dark:text-slate-400">
                                📧 Email Support: support@system.com
                            </p>

                            <p class="text-sm text-slate-600 dark:text-slate-400">
                                📞 Contact Number: +63 900 000 0000
                            </p>

                            <p class="text-sm text-slate-600 dark:text-slate-400">
                                📘 User Guide: Visit the system documentation for instructions on how to use the platform.
                            </p>
                        </div>

                    </div>

                </div>
            </div>

        </main>
    </div>

    <!-- Scripts -->
    <%- include('../partials/scripts') %>

</body>
</html>