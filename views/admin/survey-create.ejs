        // Add option to multiple choice
        function addOption(btn) {
            const container = btn.parentElement;
            const newOption = document.createElement('div');
            newOption.className = 'flex items-center gap-2 mt-1';
            newOption.innerHTML = `
                <span class="material-symbols-outlined text-slate-400">radio_button_unchecked</span>
                <input type="text" class="flex-1 border-0 outline-none bg-transparent text-sm" value="New Option">
                <span class="material-symbols-outlined text-slate-400 text-sm cursor-pointer hover:text-red-500" onclick="this.parentElement.remove()">close</span>
            `;
            container.insertBefore(newOption, btn);
        }

        // Duplicate question
        function duplicateQuestion(questionId) {
            const original = document.getElementById(questionId);
            const clone = original.cloneNode(true);
            questionCount++;
            clone.id = `q${questionCount}`;
            clone.classList.add('new');
            
            // Update cloned question's buttons to use new ID
            const duplicateBtn = clone.querySelector('[onclick*="duplicateQuestion"]');
            if (duplicateBtn) {
                duplicateBtn.setAttribute('onclick', `duplicateQuestion('q${questionCount}')`);
            }
            
            const deleteBtn = clone.querySelector('[onclick*="deleteQuestion"]');
            if (deleteBtn) {
                deleteBtn.setAttribute('onclick', `deleteQuestion('q${questionCount}')`);
            }
            
            const typeSelector = clone.querySelector('.type-selector');
            if (typeSelector) {
                typeSelector.setAttribute('onchange', `changeQuestionType(this, 'q${questionCount}')`);
            }
            
            original.parentNode.insertBefore(clone, original.nextSibling);
        }

        // Delete question
        function deleteQuestion(questionId) {
            if (confirm('Delete this question?')) {
                document.getElementById(questionId).remove();
            }
        }

        // Add section
        function addSection() {
            sectionCount++;
            const container = document.getElementById('questionsContainer');
            
            const sectionHTML = `
                <div class="card overflow-hidden" id="section${sectionCount}">
                    <div class="section-header">
                        <input type="text" value="New Section" placeholder="Section title">
                        <div class="flex items-center gap-1">
                            <button class="tool-btn" onclick="duplicateSection('section${sectionCount}')">
                                <span class="material-symbols-outlined">content_copy</span>
