                    <div class="p-5" id="questions-section${sectionCount}">
                        <!-- Empty section -->
                    </div>
                </div>
            `;
            
            container.insertAdjacentHTML('beforeend', sectionHTML);
        }

        // Delete section
        function deleteSection(sectionId) {
            if (confirm('Delete this section and all its questions?')) {
                document.getElementById(sectionId).remove();
            }
        }

        // Duplicate section
        function duplicateSection(sectionId) {
            const original = document.getElementById(sectionId);
            const clone = original.cloneNode(true);
            sectionCount++;
            clone.id = `section${sectionCount}`;
            
            // Update section buttons
            const duplicateBtn = clone.querySelector('[onclick*="duplicateSection"]');
            if (duplicateBtn) {
                duplicateBtn.setAttribute('onclick', `duplicateSection('section${sectionCount}')`);
            }
            
            const deleteBtn = clone.querySelector('[onclick*="deleteSection"]');
            if (deleteBtn) {
                deleteBtn.setAttribute('onclick', `deleteSection('section${sectionCount}')`);
            }
            
            original.parentNode.insertBefore(clone, original.nextSibling);
        }

