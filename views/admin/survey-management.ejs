<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Survey Management' }) %>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100">
    <!-- Mobile Menu Overlay -->
    <div id="mobileMenuOverlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden transition-opacity"></div>

    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <%- include('../partials/sidebar', { 
            role: 'admin', 
            currentPage: 'survey-management',
            user: user 
        }) %>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col min-w-0 h-screen overflow-hidden bg-background-light dark:bg-background-dark">
            <!-- Header -->
            <%- include('../partials/header', { 
                role: 'admin', 
                pageTitle: 'Survey Management',
                user: user 
            }) %>

            <!-- Scrollable Content Area -->
            <div class="flex-1 overflow-y-auto custom-scrollbar">
                <div class="p-4 lg:p-8">
                    <!-- Header Section with Create Button -->
                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6 lg:mb-8">
                        <div>
                            <h2 class="text-2xl lg:text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">Survey Management</h2>
                            <p class="text-sm lg:text-base text-slate-500 dark:text-slate-400 mt-1">Manage and monitor active surveys within your scope.</p>
                        </div>
                        <a href="/admin/survey-create" class="w-full sm:w-auto bg-primary hover:bg-primary/90 text-white px-4 py-2.5 sm:py-2 rounded-lg font-semibold flex items-center justify-center gap-2 transition-all shadow-lg shadow-primary/20 text-sm lg:text-base">
                            <span class="material-symbols-outlined text-lg">add</span>
                            <span>Create New Survey</span>
                        </a>
                    </div>

                    <!-- Filters & Tabs - Scrollable on mobile -->
                    <div class="mb-6 overflow-x-auto custom-scrollbar">
                        <div class="flex border-b border-slate-200 dark:border-slate-800 min-w-max">
                            <button class="px-4 lg:px-6 py-2.5 lg:py-3 border-b-2 border-primary text-primary text-xs lg:text-sm font-semibold whitespace-nowrap">Active Surveys</button>
                            <button class="px-4 lg:px-6 py-2.5 lg:py-3 border-b-2 border-transparent text-slate-500 hover:text-slate-700 dark:hover:text-slate-300 text-xs lg:text-sm font-medium whitespace-nowrap">Drafts</button>
                            <button class="px-4 lg:px-6 py-2.5 lg:py-3 border-b-2 border-transparent text-slate-500 hover:text-slate-700 dark:hover:text-slate-300 text-xs lg:text-sm font-medium whitespace-nowrap">Archived</button>
                            <button class="px-4 lg:px-6 py-2.5 lg:py-3 border-b-2 border-transparent text-slate-500 hover:text-slate-700 dark:hover:text-slate-300 text-xs lg:text-sm font-medium whitespace-nowrap">Templates</button>
                        </div>
                    </div>

                    <!-- Table Card -->
                    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
                        <div class="overflow-x-auto custom-scrollbar">
                            <table class="w-full text-left min-w-[900px] lg:min-w-0">
                                <thead class="bg-slate-50 dark:bg-slate-800/50">
                                    <tr>
                                        <th class="px-4 lg:px-6 py-3 lg:py-4 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Survey Title</th>
                                        <th class="px-4 lg:px-6 py-3 lg:py-4 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Status</th>
                                        <th class="px-4 lg:px-6 py-3 lg:py-4 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Schedule</th>
                                        <th class="px-4 lg:px-6 py-3 lg:py-4 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Response Rate</th>
                                        <th class="px-4 lg:px-6 py-3 lg:py-4 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400 text-right">Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                                    <!-- Row 1 -->
                                    <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/20 transition-colors">
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2 lg:gap-3">
                                                <div class="size-7 lg:size-8 rounded bg-primary/10 text-primary flex items-center justify-center flex-shrink-0">
                                                    <span class="material-symbols-outlined text-base lg:text-lg">description</span>
                                                </div>
                                                <span class="text-sm lg:text-base font-medium truncate max-w-[150px] lg:max-w-none">Q3 Employee Satisfaction</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <span class="inline-flex items-center gap-1 px-2 py-0.5 lg:px-2.5 lg:py-0.5 rounded-full text-[10px] lg:text-xs font-medium bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400 whitespace-nowrap">
                                                <span class="size-1.5 rounded-full bg-emerald-500"></span>
                                                Active
                                            </span>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="text-[10px] lg:text-xs">
                                                <p class="text-slate-900 dark:text-slate-300 whitespace-nowrap">Started: Sep 01, 2023</p>
                                                <p class="text-slate-500 dark:text-slate-500 whitespace-nowrap">Ends: Sep 30, 2023</p>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2 lg:gap-3">
                                                <div class="flex-1 h-1.5 lg:h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden min-w-[60px] lg:min-w-[100px]">
                                                    <div class="h-full bg-primary rounded-full" style="width: 85%;"></div>
                                                </div>
                                                <span class="text-xs lg:text-sm font-semibold whitespace-nowrap">85%</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4 text-right">
                                            <div class="flex justify-end gap-1 lg:gap-2">
                                                <button class="p-1 lg:p-1.5 text-slate-400 hover:text-primary transition-colors rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
                                                    <span class="material-symbols-outlined text-lg lg:text-xl">edit</span>
                                                </button>
                                                <button class="p-1 lg:p-1.5 text-slate-400 hover:text-primary transition-colors rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
                                                    <span class="material-symbols-outlined text-lg lg:text-xl">visibility</span>
                                                </button>
                                                <button class="p-1 lg:p-1.5 text-slate-400 hover:text-red-500 transition-colors rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
                                                    <span class="material-symbols-outlined text-lg lg:text-xl">stop_circle</span>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <!-- Row 2 -->
                                    <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/20 transition-colors">
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2 lg:gap-3">
                                                <div class="size-7 lg:size-8 rounded bg-primary/10 text-primary flex items-center justify-center flex-shrink-0">
                                                    <span class="material-symbols-outlined text-base lg:text-lg">inventory_2</span>
                                                </div>
                                                <span class="text-sm lg:text-base font-medium truncate max-w-[150px] lg:max-w-none">Product Feedback v2</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <span class="inline-flex items-center gap-1 px-2 py-0.5 lg:px-2.5 lg:py-0.5 rounded-full text-[10px] lg:text-xs font-medium bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400 whitespace-nowrap">
                                                <span class="size-1.5 rounded-full bg-emerald-500"></span>
                                                Active
                                            </span>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="text-[10px] lg:text-xs">
                                                <p class="text-slate-900 dark:text-slate-300 whitespace-nowrap">Started: Aug 15, 2023</p>
                                                <p class="text-slate-500 dark:text-slate-500 whitespace-nowrap">Ends: Oct 15, 2023</p>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2 lg:gap-3">
                                                <div class="flex-1 h-1.5 lg:h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden min-w-[60px] lg:min-w-[100px]">
                                                    <div class="h-full bg-primary rounded-full" style="width: 45%;"></div>
                                                </div>
                                                <span class="text-xs lg:text-sm font-semibold whitespace-nowrap">45%</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4 text-right">
                                            <div class="flex justify-end gap-1 lg:gap-2">
                                                <button class="p-1 lg:p-1.5 text-slate-400 hover:text-primary transition-colors rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
                                                    <span class="material-symbols-outlined text-lg lg:text-xl">edit</span>
                                                </button>
                                                <button class="p-1 lg:p-1.5 text-slate-400 hover:text-primary transition-colors rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
                                                    <span class="material-symbols-outlined text-lg lg:text-xl">visibility</span>
                                                </button>
                                                <button class="p-1 lg:p-1.5 text-slate-400 hover:text-red-500 transition-colors rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
                                                    <span class="material-symbols-outlined text-lg lg:text-xl">stop_circle</span>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <!-- Row 3 -->
                                    <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/20 transition-colors">
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2 lg:gap-3">
                                                <div class="size-7 lg:size-8 rounded bg-primary/10 text-primary flex items-center justify-center flex-shrink-0">
                                                    <span class="material-symbols-outlined text-base lg:text-lg">public</span>
                                                </div>
                                                <span class="text-sm lg:text-base font-medium truncate max-w-[150px] lg:max-w-none">Market Research - Tech</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <span class="inline-flex items-center gap-1 px-2 py-0.5 lg:px-2.5 lg:py-0.5 rounded-full text-[10px] lg:text-xs font-medium bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400 whitespace-nowrap">
                                                <span class="size-1.5 rounded-full bg-amber-500"></span>
                                                Draft
                                            </span>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="text-[10px] lg:text-xs">
                                                <p class="text-slate-500 italic whitespace-nowrap">Not scheduled</p>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2 lg:gap-3">
                                                <div class="flex-1 h-1.5 lg:h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden min-w-[60px] lg:min-w-[100px]">
                                                    <div class="h-full bg-slate-300 dark:bg-slate-700 rounded-full" style="width: 0%;"></div>
                                                </div>
                                                <span class="text-xs lg:text-sm font-semibold text-slate-400 whitespace-nowrap">0%</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4 text-right">
                                            <div class="flex justify-end gap-1 lg:gap-2">
                                                <button class="p-1 lg:p-1.5 text-slate-400 hover:text-primary transition-colors rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
                                                    <span class="material-symbols-outlined text-lg lg:text-xl">edit</span>
                                                </button>
                                                <button class="p-1 lg:p-1.5 text-slate-400 hover:text-primary transition-colors rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
                                                    <span class="material-symbols-outlined text-lg lg:text-xl">publish</span>
                                                </button>
                                                <button class="p-1 lg:p-1.5 text-slate-400 hover:text-red-500 transition-colors rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
                                                    <span class="material-symbols-outlined text-lg lg:text-xl">delete</span>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <!-- Row 4 -->
                                    <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/20 transition-colors">
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2 lg:gap-3">
                                                <div class="size-7 lg:size-8 rounded bg-primary/10 text-primary flex items-center justify-center flex-shrink-0">
                                                    <span class="material-symbols-outlined text-base lg:text-lg">groups</span>
                                                </div>
                                                <span class="text-sm lg:text-base font-medium truncate max-w-[150px] lg:max-w-none">Community Outreach</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <span class="inline-flex items-center gap-1 px-2 py-0.5 lg:px-2.5 lg:py-0.5 rounded-full text-[10px] lg:text-xs font-medium bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-400 whitespace-nowrap">
                                                <span class="size-1.5 rounded-full bg-slate-500"></span>
                                                Closed
                                            </span>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="text-[10px] lg:text-xs">
                                                <p class="text-slate-900 dark:text-slate-300 whitespace-nowrap">Started: Jul 01, 2023</p>
                                                <p class="text-slate-500 dark:text-slate-500 whitespace-nowrap">Ended: Jul 31, 2023</p>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4">
                                            <div class="flex items-center gap-2 lg:gap-3">
                                                <div class="flex-1 h-1.5 lg:h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden min-w-[60px] lg:min-w-[100px]">
                                                    <div class="h-full bg-primary/60 rounded-full" style="width: 100%;"></div>
                                                </div>
                                                <span class="text-xs lg:text-sm font-semibold whitespace-nowrap">100%</span>
                                            </div>
                                        </td>
                                        <td class="px-4 lg:px-6 py-3 lg:py-4 text-right">
                                            <div class="flex justify-end gap-1 lg:gap-2">
                                                <button class="p-1 lg:p-1.5 text-slate-400 hover:text-primary transition-colors rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
                                                    <span class="material-symbols-outlined text-lg lg:text-xl">analytics</span>
                                                </button>
                                                <button class="p-1 lg:p-1.5 text-slate-400 hover:text-primary transition-colors rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
                                                    <span class="material-symbols-outlined text-lg lg:text-xl">visibility</span>
                                                </button>
                                                <button class="p-1 lg:p-1.5 text-slate-400 hover:text-primary transition-colors rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800" title="Re-open">
                                                    <span class="material-symbols-outlined text-lg lg:text-xl">refresh</span>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination - Responsive -->
                        <div class="px-4 lg:px-6 py-3 lg:py-4 bg-slate-50 dark:bg-slate-800/50 flex flex-col sm:flex-row items-center justify-between gap-4">
                            <p class="text-xs lg:text-sm text-slate-500 dark:text-slate-400">Showing 1 to 4 of 24 surveys</p>
                            <div class="flex gap-1 lg:gap-2">
                                <button class="px-2 lg:px-3 py-1 border border-slate-300 dark:border-slate-700 rounded text-xs lg:text-sm hover:bg-white dark:hover:bg-slate-800 transition-colors disabled:opacity-50" disabled>Previous</button>
                                <button class="px-2 lg:px-3 py-1 bg-primary text-white rounded text-xs lg:text-sm hover:bg-primary/90 transition-colors">1</button>
                                <button class="px-2 lg:px-3 py-1 border border-slate-300 dark:border-slate-700 rounded text-xs lg:text-sm hover:bg-white dark:hover:bg-slate-800 transition-colors">2</button>
                                <button class="px-2 lg:px-3 py-1 border border-slate-300 dark:border-slate-700 rounded text-xs lg:text-sm hover:bg-white dark:hover:bg-slate-800 transition-colors">3</button>
                                <button class="px-2 lg:px-3 py-1 border border-slate-300 dark:border-slate-700 rounded text-xs lg:text-sm hover:bg-white dark:hover:bg-slate-800 transition-colors">Next</button>
                            </div>
                        </div>
                    </div>

                    <!-- Stats Overview - Responsive Grid -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6 mt-6 lg:mt-8">
                        <div class="p-4 lg:p-6 bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                            <div class="flex items-center gap-3 lg:gap-4">
                                <div class="size-10 lg:size-12 bg-primary/10 text-primary rounded-lg flex items-center justify-center flex-shrink-0">
                                    <span class="material-symbols-outlined text-xl lg:text-2xl">people</span>
                                </div>
                                <div class="min-w-0">
                                    <p class="text-xs lg:text-sm text-slate-500">Total Respondents</p>
                                    <h3 class="text-xl lg:text-2xl font-bold truncate">12,482</h3>
                                </div>
                            </div>
                            <div class="mt-3 lg:mt-4 flex items-center gap-1 text-emerald-600 text-xs lg:text-sm">
                                <span class="material-symbols-outlined text-xs lg:text-sm">trending_up</span>
                                <span class="truncate">12% from last month</span>
                            </div>
                        </div>

                        <div class="p-4 lg:p-6 bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                            <div class="flex items-center gap-3 lg:gap-4">
                                <div class="size-10 lg:size-12 bg-emerald-50 text-emerald-600 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <span class="material-symbols-outlined text-xl lg:text-2xl">check_circle</span>
                                </div>
                                <div class="min-w-0">
                                    <p class="text-xs lg:text-sm text-slate-500">Completion Rate</p>
                                    <h3 class="text-xl lg:text-2xl font-bold">78.4%</h3>
                                </div>
                            </div>
                            <div class="mt-3 lg:mt-4 flex items-center gap-1 text-emerald-600 text-xs lg:text-sm">
                                <span class="material-symbols-outlined text-xs lg:text-sm">trending_up</span>
                                <span class="truncate">4% from average</span>
                            </div>
                        </div>

                        <div class="p-4 lg:p-6 bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm sm:col-span-2 lg:col-span-1">
                            <div class="flex items-center gap-3 lg:gap-4">
                                <div class="size-10 lg:size-12 bg-blue-50 text-blue-600 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <span class="material-symbols-outlined text-xl lg:text-2xl">timer</span>
                                </div>
                                <div class="min-w-0">
                                    <p class="text-xs lg:text-sm text-slate-500">Avg. Time to Finish</p>
                                    <h3 class="text-xl lg:text-2xl font-bold">4m 32s</h3>
                                </div>
                            </div>
                            <div class="mt-3 lg:mt-4 flex items-center gap-1 text-slate-500 text-xs lg:text-sm">
                                <span class="material-symbols-outlined text-xs lg:text-sm">trending_flat</span>
                                <span class="truncate">Stable vs last period</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <%- include('../partials/scripts') %>
</body>
</html>