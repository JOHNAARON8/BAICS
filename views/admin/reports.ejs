<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Reports' }) %>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100">
    <!-- Mobile Menu Overlay -->
    <div id="mobileMenuOverlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden transition-opacity"></div>

    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <%- include('../partials/sidebar', { 
            role: 'admin', 
            currentPage: 'reports',
            user: user 
        }) %>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col min-w-0 h-screen overflow-hidden bg-background-light dark:bg-background-dark">
            <!-- Header -->
            <%- include('../partials/header', { 
                role: 'admin', 
                pageTitle: 'Reports',
                user: user 
            }) %>

            <!-- Scrollable Content Area -->
            <div class="flex-1 overflow-y-auto custom-scrollbar">
                <div class="p-4 lg:p-8">
                    <!-- Header Section -->
                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4 mb-6 lg:mb-8">
                        <div>
                            <h2 class="text-2xl lg:text-3xl font-black tracking-tight text-slate-900 dark:text-white">Reports & Risk Assessment</h2>
                            <p class="text-sm lg:text-base text-slate-500 dark:text-slate-400 mt-1">Generate and download analytical reports for BAICS baseline assessment.</p>
                        </div>
                    </div>

                    <!-- Tabs -->
                    <div class="mb-6 lg:mb-8 overflow-x-auto custom-scrollbar">
                        <div class="flex border-b border-slate-200 dark:border-slate-800 gap-4 lg:gap-8 min-w-max">
                            <button class="border-b-2 border-primary text-primary pb-2 lg:pb-3 text-xs lg:text-sm font-bold whitespace-nowrap">All Reports</button>
                        </div>
                    </div>

                    <!-- Risk Assessment Summary Cards -->
                    <section class="mb-8 lg:mb-10">
                        <h3 class="text-base lg:text-lg font-bold text-slate-900 dark:text-white mb-3 lg:mb-4">Risk Identification Summary</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4">
                            <div class="bg-white dark:bg-slate-800 p-4 lg:p-5 rounded-xl border border-slate-200 dark:border-slate-700">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <div class="w-8 h-8 lg:w-10 lg:h-10 rounded-lg bg-red-100 text-red-600 flex items-center justify-center">
                                            <span class="material-symbols-outlined text-lg lg:text-xl">warning</span>
                                        </div>
                                        <div>
                                            <p class="text-xs lg:text-sm text-slate-500">Critical Risks</p>
                                            <p class="text-xl lg:text-2xl font-black text-slate-900 dark:text-white">8</p>
                                        </div>
                                    </div>
                                    <span class="text-xs font-bold text-red-600 bg-red-50 px-2 py-1 rounded">+2</span>
                                </div>
                            </div>
                            
                            <div class="bg-white dark:bg-slate-800 p-4 lg:p-5 rounded-xl border border-slate-200 dark:border-slate-700">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <div class="w-8 h-8 lg:w-10 lg:h-10 rounded-lg bg-orange-100 text-orange-600 flex items-center justify-center">
                                            <span class="material-symbols-outlined text-lg lg:text-xl">error</span>
                                        </div>
                                        <div>
                                            <p class="text-xs lg:text-sm text-slate-500">High Risks</p>
                                            <p class="text-xl lg:text-2xl font-black text-slate-900 dark:text-white">12</p>
                                        </div>
                                    </div>
                                    <span class="text-xs font-bold text-orange-600 bg-orange-50 px-2 py-1 rounded">+4</span>
                                </div>
                            </div>
                            
                            <div class="bg-white dark:bg-slate-800 p-4 lg:p-5 rounded-xl border border-slate-200 dark:border-slate-700">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <div class="w-8 h-8 lg:w-10 lg:h-10 rounded-lg bg-yellow-100 text-yellow-600 flex items-center justify-center">
                                            <span class="material-symbols-outlined text-lg lg:text-xl">priority</span>
                                        </div>
                                        <div>
                                            <p class="text-xs lg:text-sm text-slate-500">Medium Risks</p>
                                            <p class="text-xl lg:text-2xl font-black text-slate-900 dark:text-white">24</p>
                                        </div>
                                    </div>
                                    <span class="text-xs font-bold text-yellow-600 bg-yellow-50 px-2 py-1 rounded">+3</span>
                                </div>
                            </div>
                            
                            <div class="bg-white dark:bg-slate-800 p-4 lg:p-5 rounded-xl border border-slate-200 dark:border-slate-700">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <div class="w-8 h-8 lg:w-10 lg:h-10 rounded-lg bg-green-100 text-green-600 flex items-center justify-center">
                                            <span class="material-symbols-outlined text-lg lg:text-xl">check_circle</span>
                                        </div>
                                        <div>
                                            <p class="text-xs lg:text-sm text-slate-500">Low Risks</p>
                                            <p class="text-xl lg:text-2xl font-black text-slate-900 dark:text-white">32</p>
                                        </div>
                                    </div>
                                    <span class="text-xs font-bold text-green-600 bg-green-50 px-2 py-1 rounded">+5</span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Quick Generate Section -->
                    <section class="mb-8 lg:mb-10">
                        <h3 class="text-base lg:text-lg font-bold text-slate-900 dark:text-white mb-3 lg:mb-4">Generate Quick Report</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
                            <!-- Card 1 - Baseline Assessment -->
                            <div class="bg-white dark:bg-slate-800 p-4 lg:p-5 rounded-xl border border-slate-200 dark:border-slate-700 hover:shadow-lg transition-shadow cursor-pointer group">
                                <div class="w-8 h-8 lg:w-10 lg:h-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center mb-3 lg:mb-4 group-hover:bg-primary group-hover:text-white transition-colors">
                                    <span class="material-symbols-outlined text-lg lg:text-xl">assessment</span>
                                </div>
                                <h4 class="font-bold text-sm lg:text-base text-slate-900 dark:text-white">Baseline Assessment</h4>
                                <p class="text-xs lg:text-sm text-slate-500 dark:text-slate-400 mt-1">Complete institutional risk profile and control environment evaluation.</p>
                                <div class="mt-3 lg:mt-4 flex items-center gap-2 text-primary text-[10px] lg:text-xs font-bold uppercase tracking-wider">
                                    <span>Generate now</span>
                                    <span class="material-symbols-outlined text-xs lg:text-sm">arrow_forward</span>
                                </div>
                            </div>
                            
                            <!-- Card 2 - Risk Register -->
                            <div class="bg-white dark:bg-slate-800 p-4 lg:p-5 rounded-xl border border-slate-200 dark:border-slate-700 hover:shadow-lg transition-shadow cursor-pointer group">
                                <div class="w-8 h-8 lg:w-10 lg:h-10 rounded-lg bg-red-100 text-red-600 flex items-center justify-center mb-3 lg:mb-4 group-hover:bg-red-600 group-hover:text-white transition-colors">
                                    <span class="material-symbols-outlined text-lg lg:text-xl">list_alt</span>
                                </div>
                                <h4 class="font-bold text-sm lg:text-base text-slate-900 dark:text-white">Risk Register</h4>
                                <p class="text-xs lg:text-sm text-slate-500 dark:text-slate-400 mt-1">Identified risks by department, severity level, and mitigation status.</p>
                                <div class="mt-3 lg:mt-4 flex items-center gap-2 text-red-600 text-[10px] lg:text-xs font-bold uppercase tracking-wider">
                                    <span>Generate now</span>
                                    <span class="material-symbols-outlined text-xs lg:text-sm">arrow_forward</span>
                                </div>
                            </div>
                            
                            <!-- Card 3 - Control Environment -->
                            <div class="bg-white dark:bg-slate-800 p-4 lg:p-5 rounded-xl border border-slate-200 dark:border-slate-700 hover:shadow-lg transition-shadow cursor-pointer group sm:col-span-2 lg:col-span-1">
                                <div class="w-8 h-8 lg:w-10 lg:h-10 rounded-lg bg-emerald-100 text-emerald-600 flex items-center justify-center mb-3 lg:mb-4 group-hover:bg-emerald-600 group-hover:text-white transition-colors">
                                    <span class="material-symbols-outlined text-lg lg:text-xl">security</span>
                                </div>
                                <h4 class="font-bold text-sm lg:text-base text-slate-900 dark:text-white">Control Environment</h4>
                                <p class="text-xs lg:text-sm text-slate-500 dark:text-slate-400 mt-1">Control effectiveness ratings and internal control deficiencies.</p>
                                <div class="mt-3 lg:mt-4 flex items-center gap-2 text-emerald-600 text-[10px] lg:text-xs font-bold uppercase tracking-wider">
                                    <span>Generate now</span>
                                    <span class="material-symbols-outlined text-xs lg:text-sm">arrow_forward</span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Department Risk Summary Table -->
                    <section class="mb-8 lg:mb-10">
                        <div class="flex justify-between items-center mb-3 lg:mb-4">
                            <h3 class="text-base lg:text-lg font-bold text-slate-900 dark:text-white">Department Risk Summary</h3>
                            <button class="text-primary hover:text-primary/70 text-xs lg:text-sm font-bold flex items-center gap-1">
                                View All
                                <span class="material-symbols-outlined text-sm">arrow_forward</span>
                            </button>
                        </div>
                        
                        <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 overflow-hidden">
                            <div class="overflow-x-auto custom-scrollbar">
                                <table class="w-full text-left min-w-[600px] lg:min-w-0">
                                    <thead class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-700">
                                        <tr>
                                            <th class="px-4 lg:px-6 py-3 lg:py-4 text-[10px] lg:text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Department</th>
                                            <th class="px-4 lg:px-6 py-3 lg:py-4 text-[10px] lg:text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-center">Critical</th>
                                            <th class="px-4 lg:px-6 py-3 lg:py-4 text-[10px] lg:text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-center">High</th>
                                            <th class="px-4 lg:px-6 py-3 lg:py-4 text-[10px] lg:text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-center">Medium</th>
                                            <th class="px-4 lg:px-6 py-3 lg:py-4 text-[10px] lg:text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-center">Low</th>
                                            <th class="px-4 lg:px-6 py-3 lg:py-4 text-[10px] lg:text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
                                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors">
                                            <td class="px-4 lg:px-6 py-3 lg:py-4">
                                                <div class="flex items-center gap-2">
                                                    <span class="text-xs lg:text-sm font-semibold">Top Management</span>
                                                </div>
                                            </td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-center text-xs lg:text-sm">0</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-center text-xs lg:text-sm">1</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-center text-xs lg:text-sm">2</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-center text-xs lg:text-sm">3</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-right">
                                                <span class="inline-flex px-2 py-1 text-[8px] lg:text-[10px] font-bold rounded-full bg-green-100 text-green-700">Stable</span>
                                            </td>
                                        </tr>
                                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors">
                                            <td class="px-4 lg:px-6 py-3 lg:py-4">
                                                <div class="flex items-center gap-2">
                                                    <span class="text-xs lg:text-sm font-semibold">Accounting Department</span>
                                                </div>
                                            </td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-center text-xs lg:text-sm">2</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-center text-xs lg:text-sm">3</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-center text-xs lg:text-sm">4</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-center text-xs lg:text-sm">1</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-right">
                                                <span class="inline-flex px-2 py-1 text-[8px] lg:text-[10px] font-bold rounded-full bg-red-100 text-red-700">Critical</span>
                                            </td>
                                        </tr>
                                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors">
                                            <td class="px-4 lg:px-6 py-3 lg:py-4">
                                                <div class="flex items-center gap-2">
                                                    <span class="text-xs lg:text-sm font-semibold">IT Department</span>
                                                </div>
                                            </td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-center text-xs lg:text-sm">3</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-center text-xs lg:text-sm">2</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-center text-xs lg:text-sm">3</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-center text-xs lg:text-sm">2</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-right">
                                                <span class="inline-flex px-2 py-1 text-[8px] lg:text-[10px] font-bold rounded-full bg-red-100 text-red-700">Critical</span>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </section>

                    <!-- Recent Generated Reports -->
                    <section>
                        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-3 lg:mb-4">
                            <h3 class="text-base lg:text-lg font-bold text-slate-900 dark:text-white">Recent Generated Reports</h3>
                            <div class="flex items-center gap-2 w-full sm:w-auto">
                                <div class="relative flex-1 sm:flex-none">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">search</span>
                                    <input class="w-full sm:w-48 lg:w-64 pl-9 pr-4 py-1.5 lg:py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-xs lg:text-sm focus:ring-2 focus:ring-primary focus:border-transparent outline-none" placeholder="Search reports..." type="text"/>
                                </div>
                                <button class="p-1.5 lg:p-2 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 rounded-lg hover:bg-slate-50">
                                    <span class="material-symbols-outlined text-slate-600 dark:text-slate-400 text-lg">filter_list</span>
                                </button>
                            </div>
                        </div>
                        
                        <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 overflow-hidden">
                            <div class="overflow-x-auto custom-scrollbar">
                                <table class="w-full text-left min-w-[700px] lg:min-w-0">
                                    <thead>
                                        <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-700">
                                            <th class="px-4 lg:px-6 py-3 lg:py-4 text-[10px] lg:text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Report Name</th>
                                            <th class="px-4 lg:px-6 py-3 lg:py-4 text-[10px] lg:text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Type</th>
                                            <th class="px-4 lg:px-6 py-3 lg:py-4 text-[10px] lg:text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Date Generated</th>
                                            <th class="px-4 lg:px-6 py-3 lg:py-4 text-[10px] lg:text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Size</th>
                                            <th class="px-4 lg:px-6 py-3 lg:py-4 text-[10px] lg:text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
                                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors">
                                            <td class="px-4 lg:px-6 py-3 lg:py-4">
                                                <div class="flex items-center gap-2 lg:gap-3">
                                                    <span class="material-symbols-outlined text-red-500 text-lg lg:text-xl">picture_as_pdf</span>
                                                    <span class="text-xs lg:text-sm font-semibold truncate max-w-[150px] lg:max-w-none">Baseline_Assessment_Q3.pdf</span>
                                                </div>
                                            </td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4">
                                                <span class="px-1.5 lg:px-2 py-0.5 lg:py-1 bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400 rounded text-[8px] lg:text-[10px] font-bold uppercase whitespace-nowrap">Risk Register</span>
                                            </td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-[10px] lg:text-xs text-slate-500 dark:text-slate-400 whitespace-nowrap">Oct 24, 2023 14:30</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-[10px] lg:text-xs text-slate-500 dark:text-slate-400">2.4 MB</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-right">
                                                <button class="text-primary hover:text-primary/70 font-bold text-[10px] lg:text-xs mr-2 lg:mr-4">Download</button>
                                                <button class="text-slate-400 hover:text-slate-600 p-1 rounded-lg hover:bg-slate-100">
                                                    <span class="material-symbols-outlined text-sm lg:text-base">more_vert</span>
                                                </button>
                                            </td>
                                        </tr>
                                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors">
                                            <td class="px-4 lg:px-6 py-3 lg:py-4">
                                                <div class="flex items-center gap-2 lg:gap-3">
                                                    <span class="material-symbols-outlined text-emerald-500 text-lg lg:text-xl">csv</span>
                                                    <span class="text-xs lg:text-sm font-semibold truncate max-w-[150px] lg:max-w-none">Risk_Register_Export.csv</span>
                                                </div>
                                            </td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4">
                                                <span class="px-1.5 lg:px-2 py-0.5 lg:py-1 bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400 rounded text-[8px] lg:text-[10px] font-bold uppercase whitespace-nowrap">Raw Data</span>
                                            </td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-[10px] lg:text-xs text-slate-500 dark:text-slate-400 whitespace-nowrap">Oct 23, 2023 09:15</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-[10px] lg:text-xs text-slate-500 dark:text-slate-400">12.8 MB</td>
                                            <td class="px-4 lg:px-6 py-3 lg:py-4 text-right">
                                                <button class="text-primary hover:text-primary/70 font-bold text-[10px] lg:text-xs mr-2 lg:mr-4">Download</button>
                                                <button class="text-slate-400 hover:text-slate-600 p-1 rounded-lg hover:bg-slate-100">
                                                    <span class="material-symbols-outlined text-sm lg:text-base">more_vert</span>
                                                </button>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            
                            <!-- Pagination - Responsive -->
                            <div class="px-4 lg:px-6 py-3 lg:py-4 bg-slate-50 dark:bg-slate-800/50 flex flex-col sm:flex-row items-center justify-between gap-3 border-t border-slate-200 dark:border-slate-700">
                                <p class="text-[10px] lg:text-xs text-slate-500">Showing 2 of 24 reports</p>
                                <div class="flex gap-1 lg:gap-2">
                                    <button class="px-2 lg:px-3 py-1 border border-slate-200 dark:border-slate-700 rounded text-[10px] lg:text-xs font-bold disabled:opacity-50" disabled>Previous</button>
                                    <button class="px-2 lg:px-3 py-1 bg-primary text-white rounded text-[10px] lg:text-xs font-bold">1</button>
                                    <button class="px-2 lg:px-3 py-1 border border-slate-200 dark:border-slate-700 rounded text-[10px] lg:text-xs font-bold">2</button>
                                    <button class="px-2 lg:px-3 py-1 border border-slate-200 dark:border-slate-700 rounded text-[10px] lg:text-xs font-bold">3</button>
                                    <button class="px-2 lg:px-3 py-1 border border-slate-200 dark:border-slate-700 rounded text-[10px] lg:text-xs font-bold">Next</button>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <%- include('../partials/scripts') %>
</body>
</html>