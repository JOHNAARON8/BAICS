                                                    <p class="text-xs text-slate-500">anna.reyes@agency.gov.ph</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="department-badge">Human Resources</span>
                                        </td>
                                        <td class="px-6 py-4">
                                            <p class="text-sm">+63 (2) 8345 6789</p>
                                            <p class="text-xs text-slate-500">Office: 310</p>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="status-badge status-pending">
                                                <span class="w-1.5 h-1.5 rounded-full bg-amber-600"></span>
                                                Pending
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-sm text-slate-400">Never</td>
                                        <td class="px-6 py-4">
                                            <span class="text-slate-400">Not started</span>
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            <button class="action-btn" onclick="viewOfficeHead(3)">
                                                <span class="material-symbols-outlined text-sm">visibility</span>
