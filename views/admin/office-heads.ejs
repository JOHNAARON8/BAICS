                        <div class="stat-card">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-sm text-slate-500">Total Office Heads</span>
                                <span class="material-symbols-outlined text-primary">groups</span>
                            </div>
                            <p class="text-2xl font-bold">24</p>
                            <p class="text-xs text-slate-400 mt-1">Across 16 departments</p>
                        </div>
                        
                        <div class="stat-card">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-sm text-slate-500">Active</span>
                                <span class="material-symbols-outlined text-emerald-600">check_circle</span>
                            </div>
                            <p class="text-2xl font-bold text-emerald-600">18</p>
                            <p class="text-xs text-slate-400 mt-1">75% of total</p>
                        </div>
                        
                        <div class="stat-card">
                            <div class="flex items-center justify-between mb-2">
