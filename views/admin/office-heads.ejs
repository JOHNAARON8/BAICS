                                            </button>
                                        </td>
                                    </tr>
                                    
                                    <!-- Row 4 - Inactive -->
                                    <tr class="table-row-hover" data-status="inactive" data-department="IT">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-3">
                                                <div class="w-8 h-8 rounded-full bg-red-100 flex items-center justify-center text-red-600">
                                                    <span class="material-symbols-outlined text-sm">person_off</span>
                                                </div>
                                                <div>
                                                    <p class="font-medium">Michael Tan</p>
                                                    <p class="text-xs text-slate-500">michael.tan@agency.gov.ph</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="department-badge">IT Department</span>
                                        </td>
                                        <td class="px-6 py-4">
                                            <p class="text-sm">+63 (2) 8456 7890</p>
                                            <p class="text-xs text-slate-500">Office: 401</p>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="status-badge status-inactive">
                                                <span class="w-1.5 h-1.5 rounded-full bg-red-600"></span>
