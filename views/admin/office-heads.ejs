    <script>
        // Toggle department selection in modal
        function toggleDeptSelection(show) {
            // Already handled inline
        }

        // Open Add Modal
        function openAddModal() {
            document.getElementById('modalTitle').textContent = 'Add New Office Head';
            document.getElementById('officeHeadModal').classList.remove('hidden');
        }

        // Close Modal
        function closeModal() {
            document.getElementById('officeHeadModal').classList.add('hidden');
        }

        // Close View Modal
        function closeViewModal() {
            document.getElementById('viewOfficeHeadModal').classList.add('hidden');
        }

        // Close Reset Modal
        function closeResetModal() {
            document.getElementById('resetPasswordModal').classList.add('hidden');
        }

        // View Office Head
        function viewOfficeHead(id) {
            // In production, fetch data based on ID
            document.getElementById('viewOfficeHeadModal').classList.remove('hidden');
        }

        // Edit Office Head
        function editOfficeHead(id) {
            document.getElementById('modalTitle').textContent = 'Edit Office Head';
            // Populate form with data
            document.getElementById('officeHeadModal').classList.remove('hidden');
        }

        // Edit from view modal
        function editFromView() {
            closeViewModal();
            editOfficeHead(1);
        }

        // Reset Password
        function resetPassword(id) {
            document.getElementById('resetPasswordModal').classList.remove('hidden');
        }

        // Confirm Reset
        function confirmReset() {
            alert('Password reset email sent successfully!');
            closeResetModal();
        }

        // Resend Invite
        function resendInvite(id) {
            alert('Invitation email resent to the office head.');
        }

        // Activate Now
        function activateNow(id) {
            if (confirm('Activate this account now?')) {
                alert('Account activated successfully!');
            }
        }

        // Reactivate
        function reactivate(id) {
            if (confirm('Reactivate this account?')) {
                alert('Account reactivated successfully!');
            }
        }

        // Toggle Status (Active/Inactive)
        function toggleStatus(id) {
            if (confirm('Change account status?')) {
                alert('Status updated successfully!');
            }
        }

        // Save Office Head
        function saveOfficeHead() {
            alert('Office head saved successfully!');
            closeModal();
        }

        // Filter by Status
        function filterByStatus(status) {
            // Update active pill
            document.querySelectorAll('.filter-pill').forEach(pill => {
                pill.classList.remove('active');
            });
            document.getElementById(`filter-${status}`).classList.add('active');
            
            // Filter table rows
            const rows = document.querySelectorAll('#officeHeadsTable tr');
            rows.forEach(row => {
                if (status === 'all' || row.dataset.status === status) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        // Filter by Department
        function filterByDepartment(dept) {
            const rows = document.querySelectorAll('#officeHeadsTable tr');
            rows.forEach(row => {
                if (dept === 'all' || row.dataset.department === dept) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        // Search functionality
        document.getElementById('searchInput').addEventListener('keyup', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('#officeHeadsTable tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });

        // Export Data
        function exportData() {
            alert('Exporting office heads data...');
        }

        // Bulk Invite
        function bulkInvite() {
            alert('Bulk invite functionality - would open CSV upload or email list input');
        }

        // Import CSV
        function importCSV() {
            alert('Import CSV functionality - would open file picker');
        }

        // Generate Report
        function generateReport() {
            alert('Generating office heads report...');
        }

        // Department pill selection
        document.querySelectorAll('.dept-pill').forEach(pill => {
            pill.addEventListener('click', function() {
                this.classList.toggle('selected');
                const checkbox = this.querySelector('input');
                if (checkbox) checkbox.checked = !checkbox.checked;
            });
        });
    </script>
    <%- include('../partials/scripts') %>
</body>
