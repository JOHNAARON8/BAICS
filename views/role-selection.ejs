<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BAICS - Select Role</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .role-card {
            transition: all 0.3s ease;
        }
        .role-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0,0,0,0.2);
        }
    </style>
</head>
<body class="bg-gradient-to-br from-slate-900 to-slate-700 min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-4xl">
        <!-- Logo Area -->
        <div class="text-center mb-12">
            <div class="inline-flex items-center justify-center w-24 h-24 bg-white rounded-3xl shadow-2xl mb-6">
                <span class="material-symbols-outlined text-5xl text-primary">analytics</span>
            </div>
            <h1 class="text-4xl font-black text-white">BAICS System</h1>
            <p class="text-white/80 text-lg mt-2">Baseline Assessment & Internal Control System</p>
        </div>

        <!-- Role Selection Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Admin Card -->
            <a href="/admin/admin-login" class="role-card bg-white rounded-2xl p-8 text-center group">
                <div class="w-20 h-20 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-primary/20 transition-all">
                    <span class="material-symbols-outlined text-4xl text-primary">admin_panel_settings</span>
                </div>
                <h2 class="text-2xl font-bold text-slate-800 mb-2">Admin</h2>
                <p class="text-slate-500 text-sm mb-4">Manage surveys, monitor responses, and oversee office heads</p>
                <span class="inline-flex items-center text-primary font-medium text-sm">
                    Login as Admin
                    <span class="material-symbols-outlined text-sm ml-1">arrow_forward</span>
                </span>
            </a>

            <!-- Super Admin Card -->
            <a href="/super-admin/super-admin-login" class="role-card bg-white rounded-2xl p-8 text-center group">
                <div class="w-20 h-20 bg-purple-100 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-purple-200 transition-all">
                    <span class="material-symbols-outlined text-4xl text-purple-700">security</span>
                </div>
                <h2 class="text-2xl font-bold text-slate-800 mb-2">Super Admin</h2>
                <p class="text-slate-500 text-sm mb-4">Full system control, user management, and system configuration</p>
                <span class="inline-flex items-center text-purple-700 font-medium text-sm">
                    Login as Super Admin
                    <span class="material-symbols-outlined text-sm ml-1">arrow_forward</span>
                </span>
            </a>

            <!-- Office Head Card -->
            <a href="/office-head/office-head-login" class="role-card bg-white rounded-2xl p-8 text-center group">
                <div class="w-20 h-20 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-green-200 transition-all">
                    <span class="material-symbols-outlined text-4xl text-green-700">person</span>
                </div>
                <h2 class="text-2xl font-bold text-slate-800 mb-2">Office Head</h2>
                <p class="text-slate-500 text-sm mb-4">Complete surveys, view status, and submit responses</p>
                <span class="inline-flex items-center text-green-700 font-medium text-sm">
                    Login as Office Head
                    <span class="material-symbols-outlined text-sm ml-1">arrow_forward</span>
                </span>
            </a>
        </div>
        
        <!-- Footer -->
        <p class="text-center text-white/60 text-sm mt-12">
            © 2025 BAICS System. All rights reserved.
        </p>
    </div>
</body>
</html>