    <script>
        let currentLevelFilter = 'all';
        let currentUserTypeFilter = 'all';
        let currentActionFilter = 'all';

        // Filter functions
        function filterByLevel(level) {
            currentLevelFilter = level;
            
            // Update filter pills
            document.querySelectorAll('[id^="level-"]').forEach(pill => {
                pill.classList.remove('active');
            });
            document.getElementById(`level-${level}`).classList.add('active');
            
            applyFilters();
        }

        function filterByUserType(type) {
            currentUserTypeFilter = type;
            applyFilters();
        }

        function filterByAction(action) {
            currentActionFilter = action;
            applyFilters();
        }

        function applyFilters() {
            const rows = document.querySelectorAll('#logsTable tr.log-entry');
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            
            rows.forEach(row => {
                let show = true;
                
                // Level filter
                if (currentLevelFilter !== 'all' && row.dataset.level !== currentLevelFilter) {
                    show = false;
                }
                
                // User type filter
                if (show && currentUserTypeFilter !== 'all' && row.dataset.userType !== currentUserTypeFilter) {
                    show = false;
                }
                
                // Action filter
                if (show && currentActionFilter !== 'all' && row.dataset.action !== currentActionFilter) {
                    show = false;
                }
                
                // Search filter
                if (show && searchTerm) {
                    const text = row.textContent.toLowerCase();
                    if (!text.includes(searchTerm)) show = false;
                }
                
                row.style.display = show ? '' : 'none';
            });
        }

        // Search input
        document.getElementById('searchInput').addEventListener('keyup', applyFilters);

        // Log details modal
        function viewLogDetails(id) {
            // In production, fetch log details based on ID
            document.getElementById('logDetailsModal').classList.remove('hidden');
        }

        function closeLogDetails() {
            document.getElementById('logDetailsModal').classList.add('hidden');
        }

        function exportLogs() {
            alert('Exporting logs...');
        }

        function exportSingleLog() {
            alert('Exporting single log entry...');
            closeLogDetails();
        }

        function refreshLogs() {
            alert('Refreshing logs...');
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            // Set default filters
            filterByLevel('all');
        });
    </script>
