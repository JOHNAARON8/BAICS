                                                <option>Full System</option>
                                                <option>Database Only</option>
                                                <option>Files Only</option>
                                                <option>Incremental</option>
                                            </select>
                                        </div>
                                        <div>
                                            <label class="block text-sm font-medium text-slate-700 mb-1">Frequency</label>
