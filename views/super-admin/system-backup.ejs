                                                <option>Daily</option>
                                                <option>Weekly</option>
                                                <option>Monthly</option>
                                            </select>
                                        </div>
                                    </div>
                                    
                                    <div>
                                        <label class="block text-sm font-medium text-slate-700 mb-1">Time</label>
                                        <input type="time" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" value="03:00">
                                    </div>
                                    
                                    <div>
                                        <label class="block text-sm font-medium text-slate-700 mb-1">Retention Period</label>
                                        <select class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                                            <option>7 days</option>
                                            <option>30 days</option>
                                            <option>90 days</option>
                                            <option>1 year</option>
                                            <option>Forever</option>
                                        </select>
                                    </div>
                                    
                                    <div>
                                        <label class="block text-sm font-medium text-slate-700 mb-1">Destination</label>
                                        <select class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                                            <option>Local Storage</option>
                                            <option>External Drive</option>
                                            <option>Network Storage</option>
                                            <option>Cloud (AWS S3)</option>
                                        </select>
                                    </div>
                                    
                                    <div class="flex items-center gap-2">
                                        <input type="checkbox" class="text-primary rounded" id="enableSchedule" checked>
                                        <label for="enableSchedule" class="text-sm">Enable this schedule</label>
                                    </div>
                                    
                                    <button class="w-full px-4 py-2 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90">
                                        Add Schedule
                                    </button>
                                </form>
                            </div>

                            <!-- Retention Policy -->
                            <div class="lg:col-span-2 bg-white rounded-xl border border-slate-200 p-6">
                                <h3 class="font-bold text-lg mb-4">Retention Policy</h3>
                                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                    <div class="p-4 bg-slate-50 rounded-lg">
                                        <p class="text-sm font-medium">Daily Backups</p>
                                        <p class="text-2xl font-bold text-primary">7 days</p>
                                        <p class="text-xs text-slate-500">Keep last 7 daily backups</p>
                                    </div>
                                    <div class="p-4 bg-slate-50 rounded-lg">
                                        <p class="text-sm font-medium">Weekly Backups</p>
                                        <p class="text-2xl font-bold text-primary">4 weeks</p>
                                        <p class="text-xs text-slate-500">Keep last 4 weekly backups</p>
                                    </div>
                                    <div class="p-4 bg-slate-50 rounded-lg">
                                        <p class="text-sm font-medium">Monthly Backups</p>
                                        <p class="text-2xl font-bold text-primary">12 months</p>
                                        <p class="text-xs text-slate-500">Keep monthly for 1 year</p>
                                    </div>
                                </div>
                                <p class="text-xs text-slate-400 mt-4">* Backups older than retention period are automatically deleted</p>
                            </div>
                        </div>
                    </div>

                    <!-- Tab: Restore Points -->
                    <div id="tab-restore-content" class="tab-content hidden">
                        <div class="bg-white rounded-xl border border-slate-200 p-6 mb-6">
                            <h3 class="font-bold text-lg mb-4">System Restore Points</h3>
                            <p class="text-sm text-slate-600 mb-4">Restore points are created before major system changes or updates</p>
                            
                            <div class="space-y-4">
                                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-lg hover:bg-slate-100 transition-colors cursor-pointer">
                                    <div class="flex items-center gap-4">
                                        <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center text-green-700">
                                            <span class="material-symbols-outlined">restore</span>
                                        </div>
                                        <div>
                                            <p class="font-medium">Before System Update v2.1.0</p>
                                            <p class="text-xs text-slate-500">2024-04-14 22:00:15 • Full System • 1.2 GB</p>
                                        </div>
                                    </div>
                                    <button class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium" onclick="restoreFromPoint(1)">
                                        Restore
                                    </button>
                                </div>
                                
                                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-lg hover:bg-slate-100 transition-colors cursor-pointer">
                                    <div class="flex items-center gap-4">
                                        <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center text-green-700">
                                            <span class="material-symbols-outlined">restore</span>
                                        </div>
                                        <div>
                                            <p class="font-medium">Before User Permission Changes</p>
                                            <p class="text-xs text-slate-500">2024-04-10 15:30:00 • Database Only • 845 MB</p>
                                        </div>
                                    </div>
                                    <button class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium" onclick="restoreFromPoint(2)">
                                        Restore
                                    </button>
                                </div>
                                
                                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-lg hover:bg-slate-100 transition-colors cursor-pointer">
                                    <div class="flex items-center gap-4">
                                        <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center text-green-700">
                                            <span class="material-symbols-outlined">restore</span>
                                        </div>
                                        <div>
                                            <p class="font-medium">Quarterly System Snapshot</p>
                                            <p class="text-xs text-slate-500">2024-04-01 03:00:00 • Full System • 1.1 GB</p>
                                        </div>
                                    </div>
                                    <button class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium" onclick="restoreFromPoint(3)">
                                        Restore
                                    </button>
                                </div>
                            </div>
                            
                            <button class="w-full mt-4 px-4 py-2 border border-primary text-primary rounded-lg text-sm font-medium hover:bg-primary/5" onclick="createRestorePoint()">
                                <span class="material-symbols-outlined text-sm align-middle mr-1">add</span>
                                Create New Restore Point
                            </button>
                        </div>
                    </div>

                    <!-- Tab: Backup Settings -->
                    <div id="tab-settings-content" class="tab-content hidden">
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                            <!-- General Settings -->
                            <div class="bg-white rounded-xl border border-slate-200 p-6">
                                <h3 class="font-bold text-lg mb-4">General Settings</h3>
                                
                                <div class="space-y-4">
                                    <div>
                                        <label class="block text-sm font-medium text-slate-700 mb-1">Backup Location</label>
                                        <select class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                                            <option>/var/backups (Local)</option>
                                            <option>/mnt/external (External Drive)</option>
                                            <option>//nas/backups (Network)</option>
                                            <option>s3://baics-backups (AWS S3)</option>
                                        </select>
                                    </div>
                                    
                                    <div>
                                        <label class="block text-sm font-medium text-slate-700 mb-1">Compression Level</label>
                                        <select class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                                            <option>None (Fastest)</option>
                                            <option>Normal (Balanced)</option>
                                            <option>Maximum (Slowest)</option>
                                        </select>
                                    </div>
                                    
                                    <div>
                                        <label class="block text-sm font-medium text-slate-700 mb-1">Encryption</label>
                                        <select class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                                            <option>AES-256 (Recommended)</option>
                                            <option>AES-128</option>
                                            <option>None</option>
                                        </select>
                                    </div>
                                    
                                    <div>
                                        <label class="block text-sm font-medium text-slate-700 mb-1">Backup Format</label>
                                        <select class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                                            <option>SQL + Files</option>
                                            <option>Archive (TAR.GZ)</option>
                                            <option>Compressed (ZIP)</option>
                                        </select>
                                    </div>
                                    
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <p class="font-medium">Email Notifications</p>
                                            <p class="text-xs text-slate-500">Receive backup status reports</p>
                                        </div>
                                        <label class="relative inline-flex items-center cursor-pointer">
                                            <input type="checkbox" class="sr-only peer" checked>
                                            <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary/20 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- Advanced Settings -->
                            <div class="bg-white rounded-xl border border-slate-200 p-6">
                                <h3 class="font-bold text-lg mb-4">Advanced Settings</h3>
                                
                                <div class="space-y-4">
                                    <div>
                                        <label class="block text-sm font-medium text-slate-700 mb-1">Max Backup Size</label>
                                        <input type="text" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" value="10 GB">
                                    </div>
                                    
                                    <div>
                                        <label class="block text-sm font-medium text-slate-700 mb-1">Max Backup Age</label>
                                        <select class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                                            <option>30 days</option>
                                            <option>60 days</option>
                                            <option>90 days</option>
                                            <option>180 days</option>
                                            <option>1 year</option>
                                        </select>
                                    </div>
                                    
                                    <div>
                                        <label class="block text-sm font-medium text-slate-700 mb-1">Concurrent Backups</label>
                                        <select class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                                            <option>1 (Recommended)</option>
                                            <option>2</option>
                                            <option>3</option>
                                            <option>4</option>
                                        </select>
                                    </div>
                                    
                                    <div>
                                        <label class="block text-sm font-medium text-slate-700 mb-1">Bandwidth Limit</label>
                                        <select class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                                            <option>No Limit</option>
                                            <option>10 Mbps</option>
                                            <option>25 Mbps</option>
                                            <option>50 Mbps</option>
                                            <option>100 Mbps</option>
                                        </select>
                                    </div>
                                    
                                    <div class="pt-4 border-t border-slate-200">
                                        <div class="flex items-center justify-between">
                                            <div>
                                                <p class="font-medium">Auto-cleanup</p>
                                                <p class="text-xs text-slate-500">Automatically delete old backups</p>
                                            </div>
                                            <label class="relative inline-flex items-center cursor-pointer">
                                                <input type="checkbox" class="sr-only peer" checked>
                                                <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary/20 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Save Button -->
                            <div class="lg:col-span-2 flex justify-end">
                                <button class="px-6 py-2 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90">
                                    Save Settings
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Restore Confirmation Modal -->
    <div id="restoreModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center restore-modal">
        <div class="bg-white rounded-xl max-w-md w-full mx-4 p-6">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center text-amber-600">
                    <span class="material-symbols-outlined">warning</span>
                </div>
                <h3 class="text-lg font-bold">Confirm Restore</h3>
            </div>
            
            <p class="text-sm text-slate-600 mb-4">Are you sure you want to restore from backup <span class="font-medium" id="restoreBackupName">full_backup_20250415_0300</span>?</p>
            
            <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 mb-4">
                <p class="text-xs text-amber-800">
                    <span class="font-bold">Warning:</span> This will overwrite current data. Make sure you have a recent backup of any changes made after this backup point.
                </p>
            </div>
            
            <div class="flex gap-3 justify-end">
                <button class="px-4 py-2 border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50" onclick="closeRestoreModal()">
                    Cancel
                </button>
                <button class="px-4 py-2 bg-amber-600 text-white rounded-lg text-sm font-semibold hover:bg-amber-700" onclick="confirmRestore()">
                    Proceed with Restore
                </button>
            </div>
        </div>
    </div>

    <!-- Delete Backup Confirmation Modal -->
    <div id="deleteBackupModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center restore-modal">
        <div class="bg-white rounded-xl max-w-md w-full mx-4 p-6">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center text-red-600">
                    <span class="material-symbols-outlined">delete</span>
                </div>
                <h3 class="text-lg font-bold">Delete Backup</h3>
            </div>
            
            <p class="text-sm text-slate-600 mb-4">Are you sure you want to delete this backup? This action cannot be undone.</p>
            
            <div class="flex gap-3 justify-end">
                <button class="px-4 py-2 border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50" onclick="closeDeleteModal()">
                    Cancel
                </button>
                <button class="px-4 py-2 bg-red-600 text-white rounded-lg text-sm font-semibold hover:bg-red-700" onclick="confirmDelete()">
                    Delete Backup
                </button>
            </div>
        </div>
    </div>

    <script>
        let currentTab = 'backups';

        function switchTab(tab) {
            currentTab = tab;
            
            // Update tab buttons
            document.querySelectorAll('.tab-button').forEach(btn => {
                btn.classList.remove('active');
            });
            document.getElementById(`tab-${tab}`).classList.add('active');
            
            // Show selected tab content
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.add('hidden');
            });
            document.getElementById(`tab-${tab}-content`).classList.remove('hidden');
        }

        function startBackupNow() {
            if (confirm('Start a new backup now?')) {
                alert('Backup started successfully!');
            }
        }

        function downloadBackup(id) {
            alert(`Downloading backup #${id}...`);
        }

        function restoreBackup(id) {
            document.getElementById('restoreModal').classList.remove('hidden');
        }

        function verifyBackup(id) {
            alert(`Verifying backup #${id}... This may take a few minutes.`);
        }

        function deleteBackup(id) {
            document.getElementById('deleteBackupModal').classList.remove('hidden');
        }

        function retryBackup(id) {
            if (confirm(`Retry failed backup #${id}?`)) {
                alert('Backup retry started!');
            }
        }

        function closeRestoreModal() {
            document.getElementById('restoreModal').classList.add('hidden');
        }

        function closeDeleteModal() {
            document.getElementById('deleteBackupModal').classList.add('hidden');
        }

        function confirmRestore() {
            alert('Restore process started. This may take several minutes.');
            closeRestoreModal();
        }

        function confirmDelete() {
            alert('Backup deleted successfully!');
            closeDeleteModal();
        }

        function manageSchedules() {
            alert('Schedule management panel would open here');
        }

        function restoreFromPoint(id) {
            if (confirm(`Restore from point #${id}?`)) {
                alert('Restore process started!');
            }
        }

        function createRestorePoint() {
            alert('Creating new restore point...');
        }

        function viewBackupLogs() {
            alert('Opening backup logs...');
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            switchTab('backups');
        });
    </script>
    <%- include('../partials/scripts') %>
</body>
</html>