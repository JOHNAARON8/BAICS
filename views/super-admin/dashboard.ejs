                    <div class="p-4 lg:p-6 border-b border-slate-200 dark:border-slate-800">
                        <h4 class="text-base lg:text-lg font-bold">Department Submission Status</h4>
                        <p class="text-xs lg:text-sm text-slate-500 mt-1">Real-time tracking of all 16 offices</p>
                    </div>
                    <div class="overflow-x-auto custom-scrollbar">
                        <table class="w-full text-left min-w-[700px] lg:min-w-0">
                            <thead class="bg-slate-50 dark:bg-slate-800/50 text-slate-500 uppercase text-[10px] lg:text-xs font-bold">
                                <tr>
                                    <th class="px-4 lg:px-6 py-3 lg:py-4">Department / Office</th>
                                    <th class="px-4 lg:px-6 py-3 lg:py-4 text-center">Status</th>
