    <!-- Add/Edit User Modal -->
    <div id="userModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center modal">
        <div class="bg-white rounded-xl max-w-3xl w-full mx-4 max-h-[90vh] overflow-y-auto">
            <div class="p-6 border-b border-slate-200 flex justify-between items-center sticky top-0 bg-white">
                <h2 class="text-xl font-bold" id="modalTitle">Add New User</h2>
                <button class="p-1 hover:bg-slate-100 rounded" onclick="closeModal()">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            
            <div class="p-6">
                <form id="userForm">
                    <!-- User Role Selection -->
                    <div class="mb-6">
                        <h3 class="text-sm font-semibold text-primary mb-3">User Role</h3>
                        <div class="flex gap-4">
                            <label class="flex items-center gap-2 p-3 border rounded-lg cursor-pointer hover:border-primary flex-1">
                                <input type="radio" name="role" value="admin" class="text-primary" checked>
                                <div>
                                    <span class="font-medium block">Admin</span>
                                    <span class="text-xs text-slate-500">Can manage surveys and office heads</span>
                                </div>
                            </label>
                            <label class="flex items-center gap-2 p-3 border rounded-lg cursor-pointer hover:border-primary flex-1">
                                <input type="radio" name="role" value="office-head" class="text-primary">
                                <div>
                                    <span class="font-medium block">Office Head</span>
                                    <span class="text-xs text-slate-500">Can complete surveys only</span>
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- Basic Information -->
                    <div class="mb-6">
                        <h3 class="text-sm font-semibold text-primary mb-3">Basic Information</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">First Name</label>
                                <input type="text" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" placeholder="Enter first name">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Last Name</label>
                                <input type="text" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" placeholder="Enter last name">
                            </div>
                        </div>
                    </div>
                    
                    <!-- Account Information -->
                    <div class="mb-6">
                        <h3 class="text-sm font-semibold text-primary mb-3">Account Information</h3>
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Email Address</label>
                                <input type="email" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" placeholder="email@agency.gov.ph">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Username</label>
                                <input type="text" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" placeholder="username">
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-slate-700 mb-1">Password</label>
                                    <input type="password" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" placeholder="••••••••">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-slate-700 mb-1">Confirm Password</label>
                                    <input type="password" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" placeholder="••••••••">
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Department Information (for Office Heads) -->
                    <div class="mb-6" id="deptFields">
                        <h3 class="text-sm font-semibold text-primary mb-3">Department Information</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Department</label>
                                <select class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                                    <option value="">Select Department</option>
                                    <option value="TM">Top Management</option>
                                    <option value="FIN">Finance & Accounting</option>
                                    <option value="HR">Human Resources</option>
                                    <option value="IT">IT Department</option>
                                    <option value="OPS">Operations</option>
                                    <option value="LEGAL">Legal Affairs</option>
                                    <option value="PROC">Procurement</option>
                                    <option value="AUDIT">Internal Audit</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Position/Title</label>
                                <input type="text" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" placeholder="e.g., Department Head">
                            </div>
                        </div>
                    </div>
                    
                    <!-- Account Status -->
                    <div class="mb-6">
                        <h3 class="text-sm font-semibold text-primary mb-3">Account Status</h3>
                        <div class="flex items-center gap-6">
                            <label class="flex items-center gap-2">
                                <input type="radio" name="status" value="active" class="text-primary" checked>
                                <span class="text-sm">Active</span>
                            </label>
                            <label class="flex items-center gap-2">
                                <input type="radio" name="status" value="pending" class="text-primary">
                                <span class="text-sm">Pending (send invite)</span>
                            </label>
                            <label class="flex items-center gap-2">
                                <input type="radio" name="status" value="inactive" class="text-primary">
                                <span class="text-sm">Inactive</span>
                            </label>
                        </div>
                    </div>
                    
                    <!-- Send Notification -->
                    <div class="mb-6">
                        <label class="flex items-center gap-2">
                            <input type="checkbox" class="text-primary rounded" checked>
                            <span class="text-sm">Send welcome email with login credentials</span>
                        </label>
                    </div>
                </form>
            </div>
            
            <div class="p-6 border-t border-slate-200 flex justify-end gap-3">
                <button class="px-4 py-2 border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50" onclick="closeModal()">
                    Cancel
                </button>
                <button class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90" onclick="saveUser()">
                    Create User
                </button>
            </div>
        </div>
    </div>

    <!-- View User Modal -->
    <div id="viewUserModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center modal">
        <div class="bg-white rounded-xl max-w-2xl w-full mx-4">
            <div class="p-6 border-b border-slate-200 flex justify-between items-center">
                <h2 class="text-xl font-bold">User Details</h2>
                <button class="p-1 hover:bg-slate-100 rounded" onclick="closeViewModal()">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            
            <div class="p-6">
                <div class="flex items-center gap-4 mb-6">
                    <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined text-3xl">person</span>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold" id="viewName">Maria Santos</h3>
                        <p class="text-slate-500" id="viewEmail">maria.santos@agency.gov.ph</p>
                    </div>
                    <span class="role-badge role-admin ml-auto" id="viewRole">Admin</span>
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-slate-50 p-3 rounded-lg">
                        <p class="text-xs text-slate-500">Department</p>
                        <p class="font-medium" id="viewDept">Top Management</p>
                    </div>
                    <div class="bg-slate-50 p-3 rounded-lg">
                        <p class="text-xs text-slate-500">Position</p>
                        <p class="font-medium" id="viewPosition">Admin</p>
                    </div>
                    <div class="bg-slate-50 p-3 rounded-lg">
                        <p class="text-xs text-slate-500">Username</p>
                        <p class="font-medium" id="viewUsername">maria.santos</p>
                    </div>
                    <div class="bg-slate-50 p-3 rounded-lg">
                        <p class="text-xs text-slate-500">Status</p>
                        <p class="font-medium text-emerald-600" id="viewStatus">Active</p>
                    </div>
                    <div class="bg-slate-50 p-3 rounded-lg">
                        <p class="text-xs text-slate-500">Last Active</p>
                        <p class="font-medium" id="viewLastActive">2 hours ago</p>
                    </div>
                    <div class="bg-slate-50 p-3 rounded-lg">
                        <p class="text-xs text-slate-500">Member Since</p>
                        <p class="font-medium" id="viewCreated">Jan 15, 2024</p>
                    </div>
                </div>
                
                <!-- Admin Permissions Summary -->
                <div class="mt-6">
                    <h4 class="font-medium mb-3">Permissions</h4>
                    <div class="space-y-2">
                        <div class="flex items-center gap-2 text-sm">
                            <span class="material-symbols-outlined text-green-600 text-sm">check_circle</span>
                            <span>Survey Management - Full Access</span>
                        </div>
                        <div class="flex items-center gap-2 text-sm">
                            <span class="material-symbols-outlined text-green-600 text-sm">check_circle</span>
                            <span>Office Head Management - Full Access</span>
                        </div>
                        <div class="flex items-center gap-2 text-sm">
                            <span class="material-symbols-outlined text-green-600 text-sm">check_circle</span>
                            <span>Reports & Analytics - View Only</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="p-6 border-t border-slate-200 flex justify-end gap-3">
                <button class="px-4 py-2 border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50" onclick="closeViewModal()">
                    Close
                </button>
                <button class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90" onclick="editFromView()">
                    Edit User
                </button>
            </div>
        </div>
    </div>

    <!-- Reset Password Confirmation Modal -->
    <div id="resetPasswordModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center modal">
        <div class="bg-white rounded-xl max-w-md w-full mx-4 p-6">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center text-amber-600">
                    <span class="material-symbols-outlined">key</span>
                </div>
                <h3 class="text-lg font-bold">Reset Password</h3>
            </div>
            
            <p class="text-sm text-slate-600 mb-4">This will reset the password for <span class="font-medium" id="resetUserEmail">maria.santos@agency.gov.ph</span>. A temporary password will be sent to their email.</p>
            
            <div class="flex gap-3 justify-end">
                <button class="px-4 py-2 border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50" onclick="closeResetModal()">
                    Cancel
                </button>
                <button class="px-4 py-2 bg-amber-600 text-white rounded-lg text-sm font-semibold hover:bg-amber-700" onclick="confirmReset()">
                    Reset Password
                </button>
            </div>
        </div>
    </div>

    <!-- Delete User Confirmation Modal -->
    <div id="deleteUserModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center modal">
        <div class="bg-white rounded-xl max-w-md w-full mx-4 p-6">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center text-red-600">
                    <span class="material-symbols-outlined">warning</span>
                </div>
                <h3 class="text-lg font-bold">Delete User</h3>
            </div>
            
            <p class="text-sm text-slate-600 mb-4">Are you sure you want to delete this user? This action cannot be undone.</p>
            
            <div class="flex gap-3 justify-end">
                <button class="px-4 py-2 border border-slate-300 rounded-lg text-sm font-medium hover:bg-slate-50" onclick="closeDeleteModal()">
                    Cancel
                </button>
                <button class="px-4 py-2 bg-red-600 text-white rounded-lg text-sm font-semibold hover:bg-red-700" onclick="confirmDelete()">
                    Delete User
                </button>
            </div>
        </div>
    </div>

    <script>
        let currentTab = 'all';
        let currentStatusFilter = 'all';
        let currentRoleFilter = 'all';

        // Tab switching
        function switchTab(tab) {
            currentTab = tab;
            
            // Update tab buttons
            document.querySelectorAll('.tab-button').forEach(btn => {
                btn.classList.remove('active');
            });
            document.getElementById(`tab-${tab}`).classList.add('active');
            
            // Apply filters
            applyFilters();
        }

        // Filter by status
        function filterByStatus(status) {
            currentStatusFilter = status;
            
            // Update filter pills
            document.querySelectorAll('.filter-pill').forEach(pill => {
                pill.classList.remove('active');
            });
            document.getElementById(`status-${status}`).classList.add('active');
            
            // Apply filters
            applyFilters();
        }

        // Filter by role
        function filterByRole(role) {
            currentRoleFilter = role;
            applyFilters();
        }

        // Apply all filters
        function applyFilters() {
            const rows = document.querySelectorAll('#usersTable tr.user-row');
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            
            rows.forEach(row => {
                let show = true;
                
                // Tab filter (all, admins, office-heads)
                if (currentTab !== 'all') {
                    const role = row.dataset.role;
                    if (currentTab === 'admins' && role !== 'admin') show = false;
                    if (currentTab === 'office-heads' && role !== 'office-head') show = false;
                }
                
                // Status filter
                if (show && currentStatusFilter !== 'all') {
                    if (row.dataset.status !== currentStatusFilter) show = false;
                }
                
                // Role filter
                if (show && currentRoleFilter !== 'all') {
                    if (row.dataset.role !== currentRoleFilter) show = false;
                }
                
                // Search filter
                if (show && searchTerm) {
                    const text = row.textContent.toLowerCase();
                    if (!text.includes(searchTerm)) show = false;
                }
                
                row.style.display = show ? '' : 'none';
            });
        }

        // Search input
        document.getElementById('searchInput').addEventListener('keyup', applyFilters);

        // Modal functions
        function openAddModal() {
            document.getElementById('modalTitle').textContent = 'Add New User';
            document.getElementById('userModal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('userModal').classList.add('hidden');
        }

        function closeViewModal() {
            document.getElementById('viewUserModal').classList.add('hidden');
        }

        function closeResetModal() {
            document.getElementById('resetPasswordModal').classList.add('hidden');
        }

        function closeDeleteModal() {
            document.getElementById('deleteUserModal').classList.add('hidden');
        }

        // View user
        function viewUser(id) {
            // In production, fetch user data based on ID
            document.getElementById('viewUserModal').classList.remove('hidden');
        }

        // Edit user
        function editUser(id) {
            document.getElementById('modalTitle').textContent = 'Edit User';
            // Populate form with user data
            document.getElementById('userModal').classList.remove('hidden');
        }

        // Edit from view modal
        function editFromView() {
            closeViewModal();
            editUser(1);
        }

        // Reset password
        function resetPassword(id) {
            document.getElementById('resetPasswordModal').classList.remove('hidden');
        }

        // Confirm reset
        function confirmReset() {
            alert('Password reset email sent successfully!');
            closeResetModal();
        }

        // Resend invite
        function resendInvite(id) {
            alert('Invitation email resent successfully!');
        }

        // Activate now
        function activateNow(id) {
            if (confirm('Activate this user now?')) {
                alert('User activated successfully!');
            }
        }

        // Toggle user status
        function toggleUserStatus(id) {
            if (confirm('Change user status?')) {
                alert('User status updated successfully!');
            }
        }

        // Reactivate user
        function reactivateUser(id) {
            if (confirm('Reactivate this user?')) {
                alert('User reactivated successfully!');
            }
        }

        // Delete user
        function deleteUser(id) {
            document.getElementById('deleteUserModal').classList.remove('hidden');
        }

        // Confirm delete
        function confirmDelete() {
            alert('User deleted successfully!');
            closeDeleteModal();
        }

        // Save user
        function saveUser() {
            alert('User saved successfully!');
            closeModal();
        }

        // Export users
        function exportUsers() {
            alert('Exporting users data...');
        }

        // Handle role change in form
        document.querySelectorAll('input[name="role"]').forEach(radio => {
            radio.addEventListener('change', function() {
                const deptFields = document.getElementById('deptFields');
                if (this.value === 'office-head') {
                    deptFields.style.display = 'block';
                } else {
                    deptFields.style.display = 'none';
                }
            });
        });

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            // Hide department fields for admin by default
            document.getElementById('deptFields').style.display = 'block'; // Will be hidden if admin selected
        });
    </script>
    <%- include('../partials/scripts') %>
</body>
</html>