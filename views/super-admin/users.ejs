<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'User Management' }) %>
    <style>
        .role-badge {
            padding: 4px 10px;
            border-radius: 30px;
            font-size: 11px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }
        .role-super-admin {
            background: linear-gradient(135deg, #1d3e8b 0%, #2a4a9c 100%);
            color: white;
        }
        .role-admin {
            background: #e2e8f0;
            color: #1d3e8b;
        }
        .role-office-head {
            background: #e6f7e6;
            color: #0d6632;
        }
        .status-badge {
            padding: 4px 8px;
            border-radius: 30px;
            font-size: 11px;
            font-weight: 500;
        }
        .status-active {
            background: #dcfce7;
            color: #166534;
        }
        .status-inactive {
            background: #fee2e2;
            color: #991b1b;
        }
        .status-pending {
            background: #fef3c7;
            color: #92400e;
        }
        .user-row {
            transition: all 0.2s ease;
        }
        .user-row:hover {
            background: #f8fafc;
        }
        .action-btn {
            padding: 6px;
            border-radius: 8px;
            color: #64748b;
            transition: all 0.2s;
        }
        .action-btn:hover {
            background: #f1f5f9;
            color: #1d3e8b;
        }
        .action-btn.delete:hover {
            background: #fee2e2;
            color: #dc2626;
        }
        .tab-button {
            padding: 10px 16px;
            font-weight: 500;
            font-size: 14px;
            border-bottom: 2px solid transparent;
            cursor: pointer;
            transition: all 0.2s;
        }
        .tab-button.active {
            border-bottom-color: #1d3e8b;
            color: #1d3e8b;
            font-weight: 600;
        }
        .tab-button:hover:not(.active) {
            color: #1d3e8b;
            background: #f8fafc;
        }
        .filter-pill {
            padding: 6px 14px;
            border-radius: 30px;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid #e2e8f0;
        }
        .filter-pill.active {
            background: #1d3e8b;
            color: white;
            border-color: #1d3e8b;
        }
        .filter-pill:hover:not(.active) {
            background: #f1f5f9;
        }
        .modal {
            transition: opacity 0.2s ease;
        }
        .modal.hidden {
            display: none;
        }
    </style>
</head>
<body class="bg-[#f8fafc] dark:bg-background-dark font-display">
    <!-- Mobile Menu Overlay -->
    <div id="mobileMenuOverlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden"></div>

    <div class="flex h-screen overflow-hidden">
